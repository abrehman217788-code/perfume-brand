<button class="chat-toggle" id="chatToggle" aria-label="Toggle chat">
  <span class="chat-icon"><i class="fas fa-comment-dots"></i></span>
  <span class="close-icon"><i class="fas fa-times"></i></span>
</button>
<div class="chat-window" id="chatWindow">
  <div class="chat-header">
    <div>
      <h4><i class="fas fa-robot"></i> Cafe Assistant</h4>
      <span>Online — Ask me anything!</span>
    </div>
  </div>
  <div class="chat-messages" id="chatMessages"></div>
  <div class="chat-input-area">
    <input type="text" id="chatInput" placeholder="Type a message..." aria-label="Chat message"/>
    <button id="chatSend">Send</button>
  </div>
</div>
