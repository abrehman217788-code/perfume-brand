<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Cafe Serenity — Artisan Coffee & Craft Kitchen</title>
  <meta name="description" content="Cafe Serenity offers artisan coffee, craft food, and a warm community space. Explore our menu, reserve a table, order online, and join our loyalty program."/>
  <meta name="keywords" content="cafe, coffee shop, artisan coffee, brunch, vegan options, gluten-free, downtown cafe"/>
  <meta name="robots" content="index, follow"/>
  <link rel="canonical" href="https://cafeserenity.com/"/>
  <meta property="og:title" content="Cafe Serenity — Artisan Coffee & Craft Kitchen"/>
  <meta property="og:description" content="Where every cup tells a story. Handcrafted coffee, seasonal brunch, and artisan desserts."/>
  <meta property="og:image" content="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1200"/>
  <meta property="og:type" content="website"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,600&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/styles.css"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-XXXXXXXXXX');</script>
</head>
<body>
  <!-- NAVIGATION -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="/" class="logo" aria-label="Cafe Serenity Home">Serenity</a>
      <div class="nav-links">
        <a href="/" class="nav-link">Home</a>
        <a href="/menu" class="nav-link">Menu</a>
        <a href="/reservations" class="nav-link">Reservations</a>
        <a href="/events" class="nav-link">Events</a>
        <a href="/about" class="nav-link">About</a>
        <a href="/contact" class="nav-link">Contact</a>
        <a href="/loyalty" class="nav-link">Rewards</a>
        <a href="/cart" class="nav-cart" aria-label="Shopping cart">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          <% if (cartCount > 0) { %><span class="cart-badge"><%= cartCount %></span><% } %>
        </a>
      </div>
      <button class="mobile-toggle" id="mobileToggle" aria-label="Toggle navigation menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- HERO SECTION -->
  <section class="hero" id="home">
    <div class="hero-bg-img"></div>
    <div id="hero-3d-container"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content reveal">
      <p class="hero-subtitle">Welcome to</p>
      <h1 class="hero-title">Cafe <span>Serenity</span></h1>
      <p class="hero-desc">Where every cup tells a story. Handcrafted coffee, seasonal brunch, and artisan desserts in the heart of the city.</p>
      <div class="hero-actions">
        <a href="/menu" class="btn btn-primary"><i class="fas fa-coffee"></i> Explore Menu</a>
        <a href="/reservations" class="btn btn-outline"><i class="fas fa-calendar-check"></i> Reserve a Table</a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- FEATURED MENU -->
  <section class="section" id="featured">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">From Our Kitchen</span>
        <h2 class="section-title">Featured <span class="highlight">Selections</span></h2>
        <p class="section-desc">Our chefs' handpicked favorites, crafted with seasonal ingredients and passion.</p>
      </div>
      <div class="featured-grid stagger-children reveal">
        <% menu.forEach(function(item) { %>
          <div class="featured-card tilt-3d">
            <div class="tilt-3d-inner">
              <div class="featured-card-img">
                <img src="<%= item.image %>" alt="<%= item.name %>" loading="lazy"/>
                <span class="featured-tag"><%= item.category %></span>
              </div>
              <div class="featured-card-body">
                <h3 class="featured-name"><%= item.name %></h3>
                <p class="featured-desc"><%= item.description %></p>
                <% if (item.tags && item.tags.length > 0) { %>
                  <div class="diet-tags">
                    <% item.tags.forEach(function(tag) { %>
                      <span class="diet-tag <%= tag %>"><%= tag %></span>
                    <% }); %>
                  </div>
                <% } %>
                <div class="featured-footer">
                  <span class="featured-price">$<%= item.price.toFixed(2) %></span>
                  <form action="/cart/add" method="POST">
                    <input type="hidden" name="id" value="<%= item.id %>"/>
                    <button type="submit" class="btn btn-primary btn-sm" aria-label="Add <%= item.name %> to order">
                      <i class="fas fa-plus"></i> Add
                    </button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
      <div class="section-header" style="margin-top:48px;margin-bottom:0;">
        <a href="/menu" class="btn btn-outline-dark"><i class="fas fa-arrow-right"></i> View Full Menu</a>
      </div>
    </div>
  </section>

  <!-- ABOUT / STORY -->
  <section class="section section-alt" id="about">
    <div class="container">
      <div class="story-grid">
        <div class="story-image reveal-left">
          <img src="https://images.unsplash.com/photo-1442512595331-e89e73853f31?w=800&h=1000&fit=crop&q=80" alt="Cafe Serenity interior" loading="lazy"/>
        </div>
        <div class="story-content reveal-right">
          <span class="section-tag">Our Story</span>
          <h2 class="section-title">Where <span class="highlight">Flavor</span> Meets Community</h2>
          <p>Cafe Serenity was born from a simple belief: that great coffee and good food have the power to bring people together. Founded in 2020, we've grown from a small corner cafe into a beloved community gathering place.</p>
          <p>We source our beans directly from sustainable farms, ensuring quality from origin to cup. Our kitchen creates fresh, seasonal dishes made from locally-sourced ingredients that complement our beverages perfectly.</p>
          <p class="italic" style="color:var(--terracotta);font-weight:600;">"Serenity is more than a cafe — it's a home away from home."</p>
          <a href="/about" class="btn btn-outline-dark" style="margin-top:16px;"><i class="fas fa-book-open"></i> Read Our Story</a>
        </div>
      </div>
      <div class="stats-grid reveal">
        <div class="stat-item">
          <div class="stat-number" data-target="5000">0+</div>
          <div class="stat-label">Cups Served</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" data-target="12">0+</div>
          <div class="stat-label">Unique Blends</div>
        </div>
        <div class="stat-item">
          <div class="stat-number" data-target="98">0+</div>
          <div class="stat-label">Satisfied Reviews</div>
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">What We Stand For</span>
        <h2 class="section-title">Our <span class="highlight">Values</span></h2>
      </div>
      <div class="values-grid stagger-children reveal">
        <div class="value-card tilt-3d">
          <div class="tilt-3d-inner">
            <span class="value-icon"><i class="fas fa-seedling"></i></span>
            <h3>Ethical Sourcing</h3>
            <p>Directly traded beans from family-owned farms. We prioritize transparency and sustainability in every cup.</p>
          </div>
        </div>
        <div class="value-card tilt-3d">
          <div class="tilt-3d-inner">
            <span class="value-icon"><i class="fas fa-wand-magic-sparkles"></i></span>
            <h3>Artisan Craft</h3>
            <p>Small-batch roasting and precision brewing. Our baristas are artists dedicated to the perfect extraction.</p>
          </div>
        </div>
        <div class="value-card tilt-3d">
          <div class="tilt-3d-inner">
            <span class="value-icon"><i class="fas fa-handshake"></i></span>
            <h3>Community First</h3>
            <p>A warm space for creators, workers, and friends. High-speed WiFi, cozy corners, and a welcoming smile await.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MENU PREVIEW / CATEGORIES -->
  <section class="section section-alt" id="menu-preview">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Explore</span>
        <h2 class="section-title">Our <span class="highlight">Menu</span></h2>
        <p class="section-desc">From bold espresso to refreshing teas, hearty meals to decadent desserts — there's something for everyone.</p>
      </div>
      <div class="values-grid stagger-children reveal" style="grid-template-columns:repeat(4,1fr);">
        <a href="/menu?category=coffee" class="value-card tilt-3d" style="cursor:pointer;">
          <div class="tilt-3d-inner">
            <span class="value-icon"><i class="fas fa-mug-hot"></i></span>
            <h3>Coffee</h3>
            <p>Espresso, cold brew, lattes & more</p>
          </div>
        </a>
        <a href="/menu?category=specialty" class="value-card tilt-3d" style="cursor:pointer;">
          <div class="tilt-3d-inner">
            <span class="value-icon"><i class="fas fa-leaf"></i></span>
            <h3>Specialty</h3>
            <p>Matcha, chai, seasonal creations</p>
          </div>
        </a>
        <a href="/menu?category=food" class="value-card tilt-3d" style="cursor:pointer;">
          <div class="tilt-3d-inner">
            <span class="value-icon"><i class="fas fa-utensils"></i></span>
            <h3>Food</h3>
            <p>Brunch, bowls, paninis & more</p>
          </div>
        </a>
        <a href="/menu?category=desserts" class="value-card tilt-3d" style="cursor:pointer;">
          <div class="tilt-3d-inner">
            <span class="value-icon"><i class="fas fa-cake-candles"></i></span>
            <h3>Desserts</h3>
            <p>Tiramisu, tarts, cakes & treats</p>
          </div>
        </a>
      </div>
      <div class="section-header" style="margin-top:48px;margin-bottom:0;">
        <a href="/menu" class="btn btn-outline-dark"><i class="fas fa-arrow-right"></i> Browse Full Menu</a>
      </div>
    </div>
  </section>

  <!-- CUSTOMER REVIEWS -->
  <section class="section" id="reviews">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">What Our Guests Say</span>
        <h2 class="section-title">Customer <span class="highlight">Reviews</span></h2>
      </div>
      <div class="reviews-grid stagger-children reveal">
        <% reviews.forEach(function(review) { %>
          <div class="review-card">
            <div class="review-header">
              <img src="<%= review.avatar %>" alt="<%= review.name %>" class="review-avatar" loading="lazy"/>
              <div class="review-info">
                <h4><%= review.name %></h4>
                <div class="review-stars">
                  <% for(var s = 0; s < review.rating; s++) { %><i class="fas fa-star"></i><% } %>
                </div>
              </div>
            </div>
            <p class="review-text">"<%= review.text %>"</p>
            <p class="review-date"><%= review.date %></p>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section section-alt" id="gallery">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Visual Stories</span>
        <h2 class="section-title">Our <span class="highlight">Gallery</span></h2>
        <p class="section-desc">A glimpse into the Serenity experience — our food, drinks, and the moments that make it special.</p>
      </div>
      <div class="gallery-grid reveal">
        <div class="gallery-item"><img src="https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?w=600&h=600&fit=crop&q=80" alt="Cafe interior" loading="lazy"/><div class="gallery-overlay"><span><i class="fas fa-search-plus"></i></span></div></div>
        <div class="gallery-item"><img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=300&h=300&fit=crop&q=80" alt="Pour over coffee" loading="lazy"/><div class="gallery-overlay"><span><i class="fas fa-search-plus"></i></span></div></div>
        <div class="gallery-item"><img src="https://images.unsplash.com/photo-1556679343-c7306c1976bc?w=300&h=300&fit=crop&q=80" alt="Matcha tiramisu" loading="lazy"/><div class="gallery-overlay"><span><i class="fas fa-search-plus"></i></span></div></div>
        <div class="gallery-item"><img src="https://images.unsplash.com/photo-1603046891726-36bfd10e0c3b?w=300&h=300&fit=crop&q=80" alt="Avocado toast" loading="lazy"/><div class="gallery-overlay"><span><i class="fas fa-search-plus"></i></span></div></div>
        <div class="gallery-item"><img src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=300&h=300&fit=crop&q=80" alt="Latte art" loading="lazy"/><div class="gallery-overlay"><span><i class="fas fa-search-plus"></i></span></div></div>
      </div>
    </div>
  </section>

  <!-- EVENTS PREVIEW -->
  <section class="section" id="events-preview">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Join Us</span>
        <h2 class="section-title">Upcoming <span class="highlight">Events</span></h2>
        <p class="section-desc">Live music, workshops, specials — there's always something happening at Serenity.</p>
      </div>
      <div class="events-grid stagger-children reveal">
        <% events.forEach(function(event) { %>
          <div class="event-card tilt-3d">
            <div class="tilt-3d-inner">
              <div class="event-card-img">
                <img src="<%= event.image %>" alt="<%= event.title %>" loading="lazy"/>
                <span class="event-type"><%= event.type %></span>
              </div>
              <div class="event-card-body">
                <div class="event-date"><i class="far fa-calendar-alt"></i> <%= event.date %></div>
                <h3><%= event.title %></h3>
                <p><%= event.description %></p>
                <span class="event-time"><i class="far fa-clock"></i> <%= event.time %></span>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
      <div class="section-header" style="margin-top:48px;margin-bottom:0;">
        <a href="/events" class="btn btn-outline-dark"><i class="fas fa-calendar-alt"></i> View All Events</a>
      </div>
    </div>
  </section>

  <!-- INSTAGRAM FEED -->
  <section class="section section-alt" id="instagram">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-tag">Follow Us</span>
        <h2 class="section-title"><span class="highlight">@cafeserenity</span> on Instagram</h2>
        <p class="section-desc">Tag us in your Serenity moments for a chance to be featured!</p>
      </div>
      <div class="gallery-grid reveal" style="grid-template-columns:repeat(6,1fr);">
        <% var igImages = [
          'https://images.unsplash.com/photo-1541167760496-1628856ab772?w=300&h=300&fit=crop&q=80',
          'https://images.unsplash.com/photo-1517701604599-bb29b565090c?w=300&h=300&fit=crop&q=80',
          'https://images.unsplash.com/photo-1515823064-d6e0c04616a7?w=300&h=300&fit=crop&q=80',
          'https://images.unsplash.com/photo-1555507036-ab1f4038024a?w=300&h=300&fit=crop&q=80',
          'https://images.unsplash.com/photo-1624353365286-3f8d62daad51?w=300&h=300&fit=crop&q=80',
          'https://images.unsplash.com/photo-1488477181946-6428a0291777?w=300&h=300&fit=crop&q=80'
        ]; %>
        <% igImages.forEach(function(src) { %>
          <div class="gallery-item" style="grid-column:span 1;grid-row:span 1;">
            <img src="<%= src %>" alt="Instagram feed" loading="lazy" style="aspect-ratio:1;"/>
            <div class="gallery-overlay"><span><i class="fab fa-instagram"></i></span></div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="newsletter-section" id="newsletter">
    <div class="container">
      <div class="newsletter-grid">
        <div class="newsletter-content reveal-left">
          <h2>Stay in the <span style="color:var(--gold);">Loop</span></h2>
          <p>Subscribe for exclusive offers, new menu launches, event invites, and a free drink on your birthday!</p>
        </div>
        <div class="reveal-right">
          <form class="newsletter-form" id="newsletterForm">
            <input type="email" name="email" placeholder="Enter your email" required aria-label="Email for newsletter"/>
            <button type="submit" class="btn btn-gold">Subscribe</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- MAP -->
  <section class="map-section" id="location">
    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3022.966309591936!2d-73.9857!3d40.7484!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDDCsDQ0JzU0LjIiTiA3M8KwNTknMDguNSJX!5e0!3m2!1sen!2sus!4v1" allowfullscreen loading="lazy" title="Cafe Serenity Location"></iframe>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <h3>Serenity</h3>
          <p>Where every cup tells a story. Artisan coffee, craft food, and a warm community space in the heart of the city.</p>
          <div class="footer-social">
            <a href="https://instagram.com" target="_blank" rel="noopener" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
            <a href="https://facebook.com" target="_blank" rel="noopener" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
            <a href="https://tiktok.com" target="_blank" rel="noopener" aria-label="TikTok"><i class="fab fa-tiktok"></i></a>
            <a href="https://twitter.com" target="_blank" rel="noopener" aria-label="X / Twitter"><i class="fab fa-x-twitter"></i></a>
          </div>
        </div>
        <div class="footer-links">
          <h4>Navigate</h4>
          <a href="/">Home</a>
          <a href="/menu">Menu</a>
          <a href="/reservations">Reservations</a>
          <a href="/events">Events</a>
          <a href="/about">About Us</a>
          <a href="/contact">Contact</a>
        </div>
        <div class="footer-links">
          <h4>Programs</h4>
          <a href="/loyalty">Loyalty Rewards</a>
          <a href="/giftcards">Gift Cards</a>
          <a href="/cart">Order Online</a>
          <a href="/menu?diet=vegan">Vegan Options</a>
          <a href="/menu?diet=gluten-free">Gluten-Free</a>
        </div>
        <div>
          <h4>Visit Us</h4>
          <p>42 Elm Street, Downtown<br/>Metropolis, NY 10001</p>
          <p style="margin-top:12px;"><strong style="color:var(--gold);">Hours</strong></p>
          <p>Mon–Fri: 7am – 9pm</p>
          <p>Sat–Sun: 8am – 10pm</p>
          <p style="margin-top:12px;"><i class="fas fa-phone" style="color:var(--gold);"></i> (555) 123-4567</p>
          <p><i class="fas fa-envelope" style="color:var(--gold);"></i> hello@cafeserenity.com</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Cafe Serenity. All rights reserved. | Crafted with <span style="color:var(--terracotta);">&hearts;</span></p>
      </div>
    </div>
  </footer>

  <!-- CHATBOT -->
  <button class="chat-toggle" id="chatToggle" aria-label="Toggle chat">
    <span class="chat-icon"><i class="fas fa-comment-dots"></i></span>
    <span class="close-icon"><i class="fas fa-times"></i></span>
  </button>
  <div class="chat-window" id="chatWindow">
    <div class="chat-header">
      <div>
        <h4><i class="fas fa-robot"></i> Cafe Assistant</h4>
        <span>Online — Ask me anything!</span>
      </div>
    </div>
    <div class="chat-messages" id="chatMessages"></div>
    <div class="chat-input-area">
      <input type="text" id="chatInput" placeholder="Type a message..." aria-label="Chat message"/>
      <button id="chatSend">Send</button>
    </div>
  </div>

  <script src="/js/main.js"></script>
</body>
</html>
