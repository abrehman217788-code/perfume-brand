<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Lumina Cafe - Vibrant Sanctuary</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            lumina: {
              cream: '#fff8f5',
              mint: '#4ade80',
              'mint-dark': '#006d36',
              peach: '#fb923c',
              espresso: '#221a14',
              'espresso-light': '#3d4a3e'
            }
          },
          fontFamily: {
            serif: ['Playfair Display', 'serif'],
            sans: ['Plus Jakarta Sans', 'sans-serif']
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    h1, h2, h3, h4 { font-family: 'Playfair Display', serif; }
    .glass {
      background: rgba(255, 248, 245, 0.6);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(109, 123, 109, 0.1);
    }
  </style>
</head>
<body class="bg-lumina-cream text-lumina-espresso">
  <nav class="fixed top-0 left-0 w-full z-50 glass border-b border-lumina-mint/10">
    <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">
      <a href="/" class="text-2xl font-bold font-serif text-lumina-mint-dark tracking-tighter">LUMINA</a>
      <div class="hidden md:flex items-center gap-8 font-semibold text-sm uppercase tracking-wider text-lumina-espresso-light">
        <a href="/" class="text-lumina-mint-dark border-b-2 border-lumina-mint pb-1">Home</a>
        <a href="/menu" class="hover:text-lumina-mint transition-colors">Menu</a>
        <a href="/reservations" class="hover:text-lumina-mint transition-colors">Reservations</a>
        <a href="/about" class="hover:text-lumina-mint transition-colors">Experience</a>
        <a href="/contact" class="hover:text-lumina-mint transition-colors">Contact</a>
      </div>
      <a href="/cart" class="relative text-lumina-espresso-light hover:text-lumina-mint transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
        <% if (cartCount > 0) { %>
          <span class="absolute -top-2 -right-2 bg-lumina-peach text-white text-xs rounded-full h-5 w-5 flex items-center justify-center font-bold shadow-lg shadow-lumina-peach/40"><%= cartCount %></span>
        <% } %>
      </a>
    </div>
  </nav>

  <main>
    <section class="relative h-[600px] md:h-[750px] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0 bg-lumina-cream"></div>
      <div class="absolute top-[-10%] right-[-10%] w-[50%] h-[50%] bg-lumina-mint opacity-20 blur-[120px] rounded-full"></div>
      <div class="absolute bottom-[-10%] left-[-10%] w-[50%] h-[50%] bg-lumina-peach opacity-15 blur-[120px] rounded-full"></div>
      <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
        <p class="text-lumina-mint-dark uppercase tracking-[0.4em] text-xs font-bold mb-6">Sip the Sunshine</p>
        <h1 class="text-6xl md:text-8xl font-black text-lumina-espresso mb-8 leading-[0.9] tracking-tighter">Vibrant <span class="italic text-lumina-mint-dark">Sanctuary</span></h1>
        <p class="text-lumina-espresso-light text-xl mb-12 max-w-2xl mx-auto leading-relaxed">Experience the warmth of hand-crafted espresso in a sun-drenched urban escape. Designed for digital nomads and aesthetic seekers.</p>
        <div class="flex flex-col md:flex-row gap-6 justify-center items-center">
          <a href="/menu" class="bg-lumina-mint text-lumina-espresso px-10 py-4 rounded-full font-bold uppercase tracking-wider text-sm hover:bg-lumina-mint-dark hover:text-white transition-all transform hover:-translate-y-1 shadow-xl shadow-lumina-mint/20">Explore Menu</a>
          <a href="/about" class="glass text-lumina-espresso px-10 py-4 rounded-full font-bold uppercase tracking-wider text-sm hover:bg-lumina-cream transition-all transform hover:-translate-y-1">The Experience</a>
        </div>
      </div>
    </section>

    <section class="py-24 px-6 max-w-6xl mx-auto">
      <div class="text-center mb-20">
        <p class="text-lumina-peach uppercase tracking-[0.2em] text-xs font-bold mb-4">From Our Kitchen</p>
        <h2 class="text-5xl md:text-6xl font-black text-lumina-espresso leading-[1.1]">Featured <span class="italic text-lumina-mint-dark">Selections</span></h2>
        <div class="w-20 h-1 bg-lumina-mint mx-auto mt-8 rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
        <% menu.forEach(item => { %>
          <div class="glass rounded-[2rem] overflow-hidden hover:shadow-2xl transition-all duration-500 group transform hover:-translate-y-2">
            <div class="h-56 overflow-hidden relative">
              <img src="<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"/>
              <div class="absolute top-4 right-4 glass px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest text-lumina-mint-dark">
                <%= item.category %>
              </div>
            </div>
            <div class="p-8">
              <h3 class="text-2xl font-bold text-lumina-espresso mb-3 leading-tight"><%= item.name %></h3>
              <p class="text-lumina-espresso-light text-sm mb-6 leading-relaxed"><%= item.description %></p>
              <div class="flex items-center justify-between mt-auto">
                <span class="text-lumina-mint-dark font-black text-xl">$<%= item.price.toFixed(2) %></span>
                <form action="/cart/add" method="POST">
                  <input type="hidden" name="id" value="<%= item.id %>"/>
                  <button type="submit" class="bg-lumina-espresso text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-lumina-mint hover:text-lumina-espresso transition-all duration-300 shadow-lg shadow-lumina-espresso/10">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                  </button>
                </form>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
      <div class="text-center mt-20">
        <a href="/menu" class="inline-block border-2 border-lumina-espresso text-lumina-espresso px-12 py-4 rounded-full font-bold uppercase tracking-widest text-xs hover:bg-lumina-espresso hover:text-white transition-all transform hover:scale-105">View Full Menu</a>
      </div>
    </section>

    <section class="py-24 bg-lumina-mint/5 relative overflow-hidden">
      <div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-16 text-center relative z-10">
        <div class="glass p-12 rounded-[2.5rem]">
          <div class="w-16 h-16 bg-lumina-mint/20 rounded-2xl flex items-center justify-center text-3xl mb-8 mx-auto">🌱</div>
          <h3 class="text-2xl font-bold text-lumina-espresso mb-4">Ethical Sourcing</h3>
          <p class="text-lumina-espresso-light text-sm leading-relaxed">Directly traded beans from family-owned farms. We prioritize transparency and sustainability in every cup.</p>
        </div>
        <div class="glass p-12 rounded-[2.5rem]">
          <div class="w-16 h-16 bg-lumina-peach/20 rounded-2xl flex items-center justify-center text-3xl mb-8 mx-auto">✨</div>
          <h3 class="text-2xl font-bold text-lumina-espresso mb-4">Artisan Crafted</h3>
          <p class="text-lumina-espresso-light text-sm leading-relaxed">Small-batch roasting and precision brewing. Our baristas are artists dedicated to the perfect extraction.</p>
        </div>
        <div class="glass p-12 rounded-[2.5rem]">
          <div class="w-16 h-16 bg-lumina-mint/20 rounded-2xl flex items-center justify-center text-3xl mb-8 mx-auto">🤝</div>
          <h3 class="text-2xl font-bold text-lumina-espresso mb-4">Space for You</h3>
          <p class="text-lumina-espresso-light text-sm leading-relaxed">A sun-drenched sanctuary for creators and nomads. High-speed fiber and comfortable corners await.</p>
        </div>
      </div>
    </section>
  </main>

  <footer class="bg-lumina-espresso text-lumina-cream py-20 px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="col-span-1 md:col-span-1">
        <h4 class="text-white font-black font-serif text-3xl mb-6 tracking-tighter">LUMINA</h4>
        <p class="text-sm leading-relaxed text-white/50 max-w-xs">A vibrant sanctuary designed for digital nomads and aesthetic seekers. Sip the sunshine in every cup.</p>
      </div>
      <div>
        <h4 class="text-lumina-mint font-bold uppercase tracking-widest text-xs mb-8">Navigate</h4>
        <div class="flex flex-col gap-4 text-sm font-medium">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <a href="/menu" class="hover:text-white transition-colors">Menu</a>
          <a href="/reservations" class="hover:text-white transition-colors">Reservations</a>
          <a href="/about" class="hover:text-white transition-colors">Experience</a>
          <a href="/contact" class="hover:text-white transition-colors">Contact</a>
        </div>
      </div>
      <div>
        <h4 class="text-lumina-peach font-bold uppercase tracking-widest text-xs mb-8">Hours</h4>
        <div class="flex flex-col gap-2 text-sm text-white/70">
          <p>Mon–Fri: 7am – 9pm</p>
          <p>Sat–Sun: 8am – 10pm</p>
        </div>
      </div>
      <div>
        <h4 class="text-lumina-mint font-bold uppercase tracking-widest text-xs mb-8">Visit</h4>
        <div class="flex flex-col gap-2 text-sm text-white/70">
          <p>42 Elm Street, Downtown</p>
          <p>hello@luminacafe.com</p>
          <p>(555) 123-4567</p>
        </div>
      </div>
    </div>
    <div class="border-t border-white/10 mt-16 pt-10 text-center text-[10px] uppercase tracking-[0.2em] text-white/30">
      &copy; 2026 Lumina Cafe. Crafted for the vibrant sanctuary.
    </div>
  </footer>
</body>
</html>
