<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Your Order - Lumina Cafe</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            lumina: {
              cream: '#fff8f5',
              mint: '#4ade80',
              'mint-dark': '#006d36',
              peach: '#fb923c',
              espresso: '#221a14',
              'espresso-light': '#3d4a3e'
            }
          },
          fontFamily: {
            serif: ['Playfair Display', 'serif'],
            sans: ['Plus Jakarta Sans', 'sans-serif']
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; }
    h1, h2, h3, h4 { font-family: 'Playfair Display', serif; }
    .glass {
      background: rgba(255, 248, 245, 0.6);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(109, 123, 109, 0.1);
    }
  </style>
</head>
<body class="bg-lumina-cream text-lumina-espresso font-sans">
  <nav class="fixed top-0 left-0 w-full z-50 glass border-b border-lumina-mint/10">
    <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">
      <a href="/" class="text-2xl font-bold font-serif text-lumina-mint-dark tracking-tighter">LUMINA</a>
      <div class="hidden md:flex items-center gap-8 font-semibold text-sm uppercase tracking-wider text-lumina-espresso-light">
        <a href="/" class="hover:text-lumina-mint transition-colors">Home</a>
        <a href="/menu" class="hover:text-lumina-mint transition-colors">Menu</a>
        <a href="/reservations" class="hover:text-lumina-mint transition-colors">Reservations</a>
        <a href="/about" class="hover:text-lumina-mint transition-colors">Experience</a>
        <a href="/contact" class="hover:text-lumina-mint transition-colors">Contact</a>
      </div>
      <a href="/cart" class="relative text-lumina-mint-dark transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
        <% if (cartCount > 0) { %>
          <span class="absolute -top-2 -right-2 bg-lumina-peach text-white text-xs rounded-full h-5 w-5 flex items-center justify-center font-bold shadow-lg shadow-lumina-peach/40"><%= cartCount %></span>
        <% } %>
      </a>
    </div>
  </nav>

  <main class="pt-20 min-h-screen">
    <section class="bg-lumina-espresso py-20 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-lumina-mint uppercase tracking-[0.3em] text-xs font-bold mb-4">Your Selection</p>
        <h1 class="text-5xl md:text-6xl font-black text-white tracking-tighter">Vibrant <span class="italic text-lumina-mint">Order</span></h1>
      </div>
    </section>

    <section class="py-16 px-6 max-w-4xl mx-auto">
      <% if (cart.length === 0) { %>
        <div class="text-center py-24 glass rounded-[3rem]">
          <div class="w-24 h-24 bg-lumina-mint/10 rounded-full flex items-center justify-center text-5xl mb-8 mx-auto">🛒</div>
          <h2 class="text-3xl font-black text-lumina-espresso mb-4">Your cart is empty</h2>
          <p class="text-lumina-espresso-light mb-10 italic">Your vibrant sanctuary awaits some flavor.</p>
          <a href="/menu" class="inline-block bg-lumina-mint text-lumina-espresso px-12 py-4 rounded-full font-bold uppercase tracking-widest text-xs hover:bg-lumina-mint-dark hover:text-white transition-all transform hover:scale-105 shadow-xl shadow-lumina-mint/20">Browse Menu</a>
        </div>
      <% } else { %>
        <div class="glass rounded-[2.5rem] overflow-hidden">
          <div class="hidden md:grid grid-cols-12 gap-4 p-6 bg-lumina-espresso text-white font-bold text-[10px] uppercase tracking-[0.2em]">
            <div class="col-span-5">Item</div>
            <div class="col-span-2 text-center">Price</div>
            <div class="col-span-2 text-center">Qty</div>
            <div class="col-span-2 text-center">Total</div>
            <div class="col-span-1"></div>
          </div>
          <% cart.forEach(item => { %>
            <div class="grid grid-cols-12 gap-6 items-center p-8 border-t border-lumina-mint/10">
              <div class="col-span-12 md:col-span-5 flex items-center gap-6">
                <div class="w-20 h-20 rounded-2xl overflow-hidden shadow-lg">
                  <img src="<%= item.image %>" alt="<%= item.name %>" class="w-full h-full object-cover"/>
                </div>
                <div>
                  <h3 class="font-black text-xl text-lumina-espresso"><%= item.name %></h3>
                  <span class="text-[10px] font-bold uppercase tracking-widest text-lumina-mint-dark"><%= item.category %></span>
                </div>
              </div>
              <div class="col-span-4 md:col-span-2 text-center font-bold text-lumina-espresso-light">$<%= item.price.toFixed(2) %></div>
              <div class="col-span-4 md:col-span-2 text-center">
                <form action="/cart/update" method="POST" class="inline-flex items-center gap-3">
                  <input type="hidden" name="id" value="<%= item.id %>"/>
                  <input type="number" name="qty" value="<%= item.qty %>" min="1" class="w-16 text-center glass border-none rounded-full px-3 py-2 text-sm font-bold text-lumina-espresso"/>
                  <button type="submit" class="text-lumina-mint-dark hover:text-lumina-mint text-[10px] uppercase font-black tracking-widest transition-colors">Update</button>
                </form>
              </div>
              <div class="col-span-3 md:col-span-2 text-center font-black text-xl text-lumina-mint-dark">$<%= (item.price * item.qty).toFixed(2) %></div>
              <div class="col-span-1 text-right">
                <form action="/cart/remove" method="POST">
                  <input type="hidden" name="id" value="<%= item.id %>"/>
                  <button type="submit" class="text-lumina-peach hover:text-red-600 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  </button>
                </form>
              </div>
            </div>
          <% }); %>
        </div>

        <div class="mt-10 glass rounded-[2.5rem] p-10">
          <div class="flex justify-between items-center mb-10">
            <span class="text-sm font-bold uppercase tracking-widest text-lumina-espresso-light">Order Total</span>
            <span class="text-4xl font-black text-lumina-espresso tracking-tighter">$<%= cartTotal.toFixed(2) %></span>
          </div>
          <form action="/checkout" method="POST">
            <button type="submit" class="w-full bg-lumina-mint text-lumina-espresso py-5 rounded-full font-black uppercase tracking-widest text-sm hover:bg-lumina-mint-dark hover:text-white transition-all transform hover:scale-[1.02] shadow-2xl shadow-lumina-mint/30">Complete Purchase</button>
          </form>
        </div>
      <% } %>
    </section>
  </main>

  <footer class="bg-lumina-espresso text-lumina-cream py-20 px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="col-span-1 md:col-span-1">
        <h4 class="text-white font-black font-serif text-3xl mb-6 tracking-tighter">LUMINA</h4>
        <p class="text-sm leading-relaxed text-white/50 max-w-xs">A vibrant sanctuary designed for digital nomads and aesthetic seekers. Sip the sunshine in every cup.</p>
      </div>
      <div>
        <h4 class="text-lumina-mint font-bold uppercase tracking-widest text-xs mb-8">Navigate</h4>
        <div class="flex flex-col gap-4 text-sm font-medium">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <a href="/menu" class="hover:text-white transition-colors">Menu</a>
          <a href="/reservations" class="hover:text-white transition-colors">Reservations</a>
          <a href="/about" class="hover:text-white transition-colors">Experience</a>
          <a href="/contact" class="hover:text-white transition-colors">Contact</a>
        </div>
      </div>
      <div>
        <h4 class="text-lumina-peach font-bold uppercase tracking-widest text-xs mb-8">Hours</h4>
        <div class="flex flex-col gap-2 text-sm text-white/70">
          <p>Mon–Fri: 7am – 9pm</p>
          <p>Sat–Sun: 8am – 10pm</p>
        </div>
      </div>
      <div>
        <h4 class="text-lumina-mint font-bold uppercase tracking-widest text-xs mb-8">Visit</h4>
        <div class="flex flex-col gap-2 text-sm text-white/70">
          <p>42 Elm Street, Downtown</p>
          <p>hello@luminacafe.com</p>
          <p>(555) 123-4567</p>
        </div>
      </div>
    </div>
    <div class="border-t border-white/10 mt-16 pt-10 text-center text-[10px] uppercase tracking-[0.2em] text-white/30">
      &copy; 2026 Lumina Cafe. Crafted for the vibrant sanctuary.
    </div>
  </footer>
</body>
</html>
