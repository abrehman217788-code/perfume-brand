<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Our Menu — Cafe Serenity</title>
  <meta name="description" content="Browse our full menu of artisan coffee, specialty drinks, food, and desserts with dietary tags for vegan, gluten-free, and vegetarian options."/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,600&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <link rel="stylesheet" href="/css/styles.css"/>
</head>
<body>
  <%- include('partials/nav') %>

  <section class="page-hero">
    <div class="page-hero-content">
      <span class="section-tag">Carefully Curated</span>
      <h1 class="page-title">Our <span style="color:var(--gold);">Menu</span></h1>
      <p class="page-subtitle">Handcrafted with love, from our kitchen to your table</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <!-- Category Filters -->
      <div class="filter-bar">
        <% allCategories.forEach(function(cat) { %>
          <a href="/menu?category=<%= cat %><%= activeDiet !== 'all' ? '&diet=' + activeDiet : '' %>" class="filter-btn <%= activeCategory === cat ? 'active' : '' %>">
            <%= cat === 'all' ? 'All' : cat.charAt(0).toUpperCase() + cat.slice(1) %>
          </a>
        <% }); %>
      </div>
      <!-- Diet Filters -->
      <div class="filter-bar" style="margin-bottom:48px;">
        <% allDiets.forEach(function(diet) { %>
          <a href="/menu?category=<%= activeCategory %>&diet=<%= diet %>" class="filter-btn <%= activeDiet === diet ? 'active' : '' %>">
            <%= diet === 'all' ? 'All Diets' : diet.charAt(0).toUpperCase() + diet.slice(1) %>
            <% if(diet === 'vegan') { %><i class="fas fa-leaf" style="margin-left:4px;font-size:0.7rem;"></i><% } %>
          </a>
        <% }); %>
      </div>

      <!-- Menu Grid -->
      <div class="menu-grid">
        <% if (menu.length === 0) { %>
          <div class="no-items">
            <i class="fas fa-search" style="font-size:3rem;display:block;margin-bottom:16px;color:var(--sage-light);"></i>
            <p>No items found in this category. Try a different filter!</p>
          </div>
        <% } %>
        <% menu.forEach(function(item) { %>
          <div class="menu-card tilt-3d">
            <div class="tilt-3d-inner">
              <div class="menu-card-img">
                <img src="<%= item.image %>" alt="<%= item.name %>" loading="lazy"/>
                <span class="menu-card-tag"><%= item.category %></span>
              </div>
              <div class="menu-card-body">
                <div class="menu-card-header">
                  <h3 class="menu-card-name"><%= item.name %></h3>
                  <span class="menu-card-price">$<%= item.price.toFixed(2) %></span>
                </div>
                <p class="menu-card-desc"><%= item.description %></p>
                <% if (item.tags && item.tags.length > 0) { %>
                  <div class="diet-tags">
                    <% item.tags.forEach(function(tag) { %>
                      <span class="diet-tag <%= tag %>"><%= tag %></span>
                    <% }); %>
                  </div>
                <% } %>
                <div class="menu-card-actions">
                  <form action="/cart/add" method="POST" style="width:100%;">
                    <input type="hidden" name="id" value="<%= item.id %>"/>
                    <button type="submit" class="btn btn-primary btn-full"><i class="fas fa-plus"></i> Add to Order</button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <%- include('partials/chat') %>
  <script src="/js/main.js"></script>
</body>
</html>
