<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Reservations — Lumina Cafe</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="/css/styles.css"/>
</head>
<body>
<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="logo">LUMINA</a>
    <div class="nav-links">
      <a href="/" class="nav-link">Home</a>
      <a href="/menu" class="nav-link">Menu</a>
      <a href="/reservations" class="nav-link active">Reservations</a>
      <a href="/experience" class="nav-link">Experience</a>
    </div>
    <button class="mobile-toggle" id="mobileToggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<section class="page-hero">
  <div class="container">
    <p class="hero-subtitle">Book Your Experience</p>
    <h1 class="page-title">Reservations</h1>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="reservation-layout">
      <div class="reservation-info">
        <span class="section-tag">Join Us</span>
        <h2 class="section-title">Reserve a <span class="italic">Table</span></h2>
        <p>Whether it's a quiet morning coffee, a business lunch, or a special celebration — we'd love to host you.</p>
        <div class="reservation-details">
          <div class="res-detail">
            <strong>Hours</strong>
            <p>Mon–Fri: 7am – 9pm</p>
            <p>Sat–Sun: 8am – 10pm</p>
          </div>
          <div class="res-detail">
            <strong>Contact</strong>
            <p>42 Elm Street, Downtown</p>
            <p>(555) 123-4567</p>
          </div>
        </div>
      </div>

      <form class="reservation-form" action="/api/reservations" method="POST">
        <% if (typeof success !== 'undefined' && success) { %>
          <div class="alert alert-success"><%= success %></div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <div class="form-group">
          <label for="name">Name *</label>
          <input type="text" id="name" name="name" required placeholder="Your full name"/>
        </div>
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required placeholder="your@email.com"/>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="date">Date *</label>
            <input type="date" id="date" name="date" required/>
          </div>
          <div class="form-group">
            <label for="time">Time *</label>
            <input type="time" id="time" name="time" required/>
          </div>
        </div>
        <div class="form-group">
          <label for="guests">Number of Guests *</label>
          <select id="guests" name="guests" required>
            <option value="">Select...</option>
            <% for (let i = 1; i <= 8; i++) { %>
              <option value="<%= i %>"><%= i %> <%= i === 1 ? 'Guest' : 'Guests' %></option>
            <% } %>
          </select>
        </div>
        <div class="form-group">
          <label for="notes">Special Requests</label>
          <textarea id="notes" name="notes" rows="3" placeholder="Allergies, celebrations, seating preferences..."></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Confirm Reservation</button>
      </form>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <h3>LUMINA</h3>
        <p>Light. Flavor. Community.</p>
      </div>
      <div class="footer-links">
        <h4>Navigate</h4>
        <a href="/">Home</a>
        <a href="/menu">Menu</a>
        <a href="/reservations">Reservations</a>
        <a href="/experience">Experience</a>
      </div>
      <div class="footer-hours">
        <h4>Hours</h4>
        <p>Mon–Fri: 7am – 9pm</p>
        <p>Sat–Sun: 8am – 10pm</p>
      </div>
      <div class="footer-contact">
        <h4>Visit</h4>
        <p>42 Elm Street, Downtown</p>
        <p>hello@luminacafe.com</p>
        <p>(555) 123-4567</p>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Lumina Cafe. All rights reserved.</p>
    </div>
  </div>
</footer>

<script src="/js/main.js"></script>
</body>
</html>
