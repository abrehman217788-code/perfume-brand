{
  "name": "velora-ecommerce",
  "version": "1.0.0",
  "description": "VELORA - Modern E-Commerce Platform with Express, MongoDB, Stripe payments, reviews, and admin dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node seed.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit"
  },
  "keywords": [
    "ecommerce",
    "express",
    "mongodb",
    "stripe",
    "node"
  ],
  "author": "VELORA",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "jest": "^30.4.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["utils/**/*.js", "middleware/**/*.js", "config/**/*.js"]
  }
}
