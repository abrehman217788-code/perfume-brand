<%- include('partials/header') %>

<main style="padding-top: 8rem;">
    <section>
        <h1 class="section-title" style="text-align: left; font-size: 3.5rem;">SELECTED WORKS</h1>
        <p style="color: var(--text-muted); max-width: 800px; font-size: 1.1rem; margin-bottom: 4rem;">A showcase of our architectural precision and technical expertise. We take pride in delivering robust solutions for complex challenges.</p>

        <div class="grid-2">
            <% projects.forEach(project => { %>
                <div class="glass card glass-glow-cyan" style="padding: 0; overflow: hidden;">
                    <div class="portfolio-item" style="aspect-ratio: 16/9; border-radius: 0;">
                        <img src="<%= project.image %>" alt="<%= project.title %>" class="portfolio-img">
                    </div>
                    <div style="padding: 2.5rem;">
                        <span style="color: var(--secondary); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em;"><%= project.category %></span>
                        <h2 style="font-size: 1.75rem; margin: 1rem 0;"><%= project.title %></h2>
                        <p style="margin-bottom: 2rem;"><%= project.description %></p>
                        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
                            <% project.tech.forEach(t => { %>
                                <span class="glass" style="padding: 0.4rem 1rem; border-radius: var(--radius-sm); font-size: 0.75rem; color: var(--text-muted); border: 1px solid var(--outline);"><%= t %></span>
                            <% }) %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
