<body class="bg-background text-on-background antialiased min-h-screen flex flex-col pt-20">
<!-- TopAppBar -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-20 bg-white dark:bg-black docked full-width border-b-3 border-black dark:border-white">
<div class="flex items-center gap-6">
<span class="text-3xl font-black tracking-tighter text-black dark:text-white">STREET_ARCHIVE</span>
</div>
<nav class="hidden md:flex items-center gap-8 font-inter uppercase tracking-tighter font-black text-sm text-black dark:text-white">
<a class="text-black dark:text-white border-b-3 border-black dark:border-white pb-1 Active: translate-y-0.5 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors duration-100" href="/shop">SHOP</a>
<a class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors duration-100" href="/product">DROPS</a>
<a class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors duration-100" href="/">COLLECTIONS</a>
<a class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors duration-100" href="/about">LAB</a>
</nav>
<div class="flex items-center gap-4 text-black dark:text-white">
<% if (user) { %>
  <span>Welcome, <%= user.email %></span>
  <a href="/logout" class="hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors duration-100 p-2">
    <span class="material-symbols-outlined">logout</span>
  </a>
<% } else { %>
  <a href="/login" class="hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors duration-100 p-2">
    <span class="material-symbols-outlined">person</span>
  </a>
<% } %>
<button class="hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors duration-100 p-2">
<span class="material-symbols-outlined">shopping_bag</span>
</button>
</div>
</header>
<main class="flex-grow flex flex-col">
<!-- Hero Section -->
<section class="relative h-[870px] w-full border-b-3 border-white flex flex-col justify-end p-margin" data-alt="A gritty, high-contrast black and white photograph of an urban concrete staircase leading to a harsh industrial structure. The lighting is extremely dramatic, with stark, heavy shadows and bright, blown-out highlights emphasizing the raw texture of the concrete. The overall aesthetic perfectly captures a modern brutalist streetwear vibe, evoking a sense of underground exclusivity and stark architectural geometry within a deep dark mode palette." style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBuj5fEmFbIvGneMdOKQyq6XfuEL6RWZf5yoILnGl4zbeD3fNTrmrNz7FBPPsHGldaP5EjzmnCbOTpznHkN3ED3uJuTuZTcaKSOaO2id-m_yWQqT84swHIc2yjAr6rW_rIrLnwXM-Tke02gWPeGrBvy5qrEHYYhfaJnqV6EZ6nUZNMxDZzkzm10Oy0vkDS9N9IR764pelFGVBT5yei_Ue4CY9xitwCZe0X6DRzdQHpl-NK3zlGUgb6Ad-Zs3jJhNGkzJh4I8LS2L_c'); background-size: cover; background-position: center;">
<div class="absolute inset-0 bg-black/40"></div>
<div class="relative z-10 max-w-container-max mx-auto w-full grid grid-cols-12 gap-gutter">
<div class="col-span-12 md:col-span-8">
<h1 class="font-headline-2xl text-headline-2xl text-white uppercase mb-6 drop-shadow-xl">ARCHIVE 01:<br/>THE NEW STANDARD</h1>
<button class="bg-white text-black font-label-bold text-label-bold uppercase border-3 border-white px-8 py-4 hover:bg-black hover:text-white transition-colors duration-100 inline-flex items-center gap-2">
                        SHOP NOW <span class="material-symbols-outlined">arrow_forward</span>
</button>
</div>
</div>
</section>
<!-- Featured Drops -->
<section class="py-[128px] px-margin max-w-container-max mx-auto w-full border-b-3 border-white">
<div class="flex justify-between items-end mb-16 border-b-3 border-white pb-6">
<h2 class="font-headline-xl text-headline-xl uppercase">FEATURED DROPS</h2>
<a class="font-label-bold text-label-bold uppercase hover:text-tertiary transition-colors duration-100 flex items-center gap-1" href="/shop">VIEW ALL <span class="material-symbols-outlined">north_east</span></a>
</div>
<div class="grid grid-cols-12 gap-gutter">
<% if (typeof products !== 'undefined' && products.length > 0) { %>
  <% products.slice(0, 3).forEach((product, index) => { %>
    <a href="/product/<%= product._id || product.id %>" class="col-span-12 md:col-span-4 border-3 border-white group relative cursor-pointer block <%= product.isSoldOut ? 'opacity-75 grayscale' : '' %>">
      <% if (product.isSoldOut) { %>
        <div class="absolute inset-0 bg-black/50 z-10 flex items-center justify-center">
          <span class="bg-black text-white font-headline-lg text-headline-lg px-6 py-2 border-3 border-white -rotate-12">SOLD OUT</span>
        </div>
      <% } else if (product.isNewDrop) { %>
        <div class="absolute top-4 left-4 z-10 bg-tertiary text-black px-3 py-1 font-label-mono text-label-mono border-3 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] dark:shadow-[4px_4px_0px_0px_rgba(255,255,255,1)]">NEW DROP</div>
      <% } %>
      <div class="h-[400px] w-full border-b-3 border-white overflow-hidden bg-surface-container">
        <img alt="<%= product.name %>" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-300" src="<%= product.image %>"/>
      </div>
      <div class="p-6 bg-background group-hover:bg-white group-hover:text-black transition-colors duration-100 h-full">
        <p class="font-label-mono text-label-mono mb-2 text-primary group-hover:text-gray-500"><%= product.sku || product.code %></p>
        <h3 class="font-headline-lg text-headline-lg leading-tight uppercase"><%= product.name %></h3>
        <div class="mt-4 flex justify-between items-center border-t-1 border-white group-hover:border-black pt-4">
          <span class="font-label-bold text-label-bold">$<%= product.price %>.00</span>
          <span class="material-symbols-outlined"><%= product.isSoldOut ? 'close' : 'add' %></span>
        </div>
      </div>
    </a>
  <% }); %>
<% } %>
</div>
</section>

<!-- Brand Storytelling -->
<section class="py-[160px] px-margin max-w-container-max mx-auto w-full grid grid-cols-12 gap-gutter items-center">
<div class="col-span-12 md:col-span-5 flex flex-col gap-8">
<h2 class="font-headline-xl text-headline-xl uppercase leading-none">NO<br/>COMPROMISE.<br/>JUST<br/>STRUCTURE.</h2>
<div class="w-full h-1 bg-white"></div>
<p class="font-body-lg text-body-lg text-primary max-w-md">STREET_ARCHIVE rejects the transient nature of modern fashion. We build modular, brutalist garments designed for utility and permanence. Engineered in the shadows, built for the concrete.</p>
<button class="self-start bg-transparent text-white font-label-bold text-label-bold uppercase border-3 border-white px-8 py-4 hover:bg-white hover:text-black transition-colors duration-100 inline-flex items-center gap-2">
                    READ THE MANIFESTO
                </button>
</div>
<div class="col-span-12 md:col-span-7 grid grid-cols-2 gap-gutter relative h-[600px]">
<div class="border-3 border-white h-full relative z-10 translate-y-12">
<img alt="Urban brutalist architecture" class="w-full h-full object-cover grayscale" data-alt="A claustrophobic view looking straight up at massive, overlapping brutalist concrete apartment buildings against a stark, featureless sky. The image is strictly black and white with heavy contrast, emphasizing the harsh geometric lines and aggressive, imposing scale of the architecture. This gritty, urban aesthetic serves as the conceptual foundation for a stark dark mode streetwear brand." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDY_oyLK1MdpbE1hokLJAhapwKxSMdM_FfLsFkARPeRfpuiVanrKzse32cEAWmNKsVFO2B90xNMmdieN3UdGuC6mPRqhRGptWJMXLFzzQcvaQKprJav2FrLlyR4qJbpZKlFG8r17wGWBUgz_kRUjNsXvbx9jxA3Uhtebcj-WtwqL7AJF4IfMS-ncx36FSmDk5V-A_ig4wguyGwcrY4vZ87K69LCSvxVclN6UxRtE2ljbHVw_f7V2Y1MSZLQRZpYG3erfHF0nbT_Go0"/>
</div>
<div class="border-3 border-white h-[80%] relative z-0 -translate-y-8 bg-surface-container">
<img alt="Person wearing streetwear in alley" class="w-full h-full object-cover grayscale" data-alt="A solitary figure wearing dark, structured, oversized streetwear stands in an oppressive, narrow concrete alleyway. Heavy film grain and extreme high-contrast black and white lighting obscure the figure's face, focusing entirely on the silhouette and the heavy drape of the garments against the raw, dirty textures of the urban environment. A perfect execution of modern brutalist fashion photography." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCYFfqwhYuZdGqOAH1QSFqQjoTigqSH-VBRazP3rq_hARJ6MQQgQIjFVgfd4q8qLkuPTyiE6Q_wZ2Z_PveZZc8Z2y7EpOwxBE8RjLbUan2gn7Uae61zBqI2QulauxC0buRReocePdYoCjRPQxM2dNHHu_UkzmhsH5bC5O8JUZIDjDqGEN8Rb4cm2gMZz3ttliRo_KcyBQhqIcXtaE9tKJ5xlFjNfqpWIhqOIHmmirceHAFWloRwUfvzRR0D9Eyf5bxgqcaJ2XuBGpg"/>
</div>
</div>
</section>
</main>
<!-- Footer -->
<footer class="w-full py-12 px-10 grid grid-cols-12 gap-6 items-end bg-white dark:bg-black text-black dark:text-white font-inter font-bold uppercase text-xs tracking-widest docked full-width border-t-3 border-black dark:border-white">
<div class="col-span-12 md:col-span-6 flex flex-col gap-4">
<span class="text-xl font-black text-black dark:text-white">STREET_ARCHIVE</span>
<p>©2024 STREET_ARCHIVE. ALL RIGHTS RESERVED.</p>
</div>
<div class="col-span-12 md:col-span-6 flex flex-wrap justify-end gap-8">
<a class="text-black dark:text-white hover:invert transition-all duration-75 Active: scale-95" href="#">PRIVACY</a>
<a class="text-black dark:text-white hover:invert transition-all duration-75 Active: scale-95" href="#">TERMS</a>
<a class="text-black dark:text-white hover:invert transition-all duration-75 Active: scale-95" href="#">SHIPPING</a>
<a class="text-black dark:text-white hover:invert transition-all duration-75 Active: scale-95" href="#">CONTACT</a>
</div>
</footer>
</body></html></content>
