<%- include('partials/header') %>

<main>
  <!-- 3D Hero -->
  <section class="hero" id="hero">
    <canvas id="heroCanvas"></canvas>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-badge">SS26 Collection</div>
      <h1 class="hero-title">CONCRETE<br>SEASONS</h1>
      <p class="hero-sub">Brutalist silhouettes meet raw urban architecture. The new standard in heavyweight streetwear.</p>
      <div class="hero-actions">
        <a href="/shop" class="btn btn-primary">Explore Collection <i class="fa-regular fa-arrow-right"></i></a>
        <a href="/lookbooks" class="btn btn-outline">View Lookbook <i class="fa-regular fa-eye"></i></a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat"><span class="hero-stat-num">25</span><span class="hero-stat-label">Drops</span></div>
        <div class="hero-stat"><span class="hero-stat-num">12K</span><span class="hero-stat-label">Holders</span></div>
        <div class="hero-stat"><span class="hero-stat-num">4.9</span><span class="hero-stat-label">Rating</span></div>
      </div>
    </div>
  </section>

  <!-- Lookbook Carousel -->
  <section class="section" id="lookbooks">
    <div class="section-head">
      <div>
        <span class="section-tag">Curated</span>
        <h2 class="section-title">Lookbooks</h2>
      </div>
      <a href="/lookbooks" class="section-link">View All <i class="fa-regular fa-arrow-right"></i></a>
    </div>
    <div class="lookbook-carousel" id="lookbookCarousel">
      <% if (typeof lookbooks !== 'undefined' && lookbooks.length > 0) { %>
        <% lookbooks.forEach(function(lb) { %>
          <div class="lookbook-card">
            <div class="lookbook-image">
              <img src="<%= lb.image %>" alt="<%= lb.title %>" loading="lazy">
              <div class="lookbook-overlay">
                <span class="lookbook-sub"><%= lb.subtitle %></span>
                <h3 class="lookbook-title"><%= lb.title %></h3>
                <p class="lookbook-desc"><%= lb.description %></p>
                <a href="/shop" class="btn btn-sm btn-primary">Shop Look <i class="fa-regular fa-arrow-right"></i></a>
              </div>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="section" id="featured">
    <div class="section-head">
      <div>
        <span class="section-tag">Latest Drops</span>
        <h2 class="section-title">Featured Gear</h2>
      </div>
      <a href="/shop" class="section-link">Shop All <i class="fa-regular fa-arrow-right"></i></a>
    </div>
    <div class="product-grid">
      <% if (typeof products !== 'undefined' && products.length > 0) { %>
        <% products.slice(0, 4).forEach(function(p) { %>
          <a href="/product/<%= p.id %>" class="product-card <%= p.isSoldOut ? 'sold-out' : '' %>">
            <div class="product-card-image">
              <img src="<%= p.image %>" alt="<%= p.name %>" loading="lazy">
              <% if (p.isNewDrop) { %><span class="product-badge new">New</span><% } %>
              <% if (p.isLimited) { %><span class="product-badge limited">Limited</span><% } %>
              <% if (p.isSoldOut) { %><span class="product-badge sold">Sold Out</span><% } %>
              <% if (p.originalPrice) { %><span class="product-badge sale">Sale</span><% } %>
            </div>
            <div class="product-card-body">
              <span class="product-card-sku"><%= p.sku %></span>
              <h3 class="product-card-title"><%= p.name %></h3>
              <div class="product-card-footer">
                <span class="product-card-price">
                  <% if (p.originalPrice) { %><del>$<%= p.originalPrice %></del> <% } %>
                  $<%= p.price %>
                </span>
                <span class="product-card-rating"><i class="fa-regular fa-star"></i> <%= p.rating %></span>
              </div>
            </div>
          </a>
        <% }); %>
      <% } %>
    </div>
  </section>

  <!-- Style Quiz CTA -->
  <section class="section section-dark quiz-cta">
    <div class="quiz-cta-bg"></div>
    <div class="quiz-cta-content">
      <span class="section-tag">Find Your Fit</span>
      <h2 class="section-title" style="font-size: clamp(2.5rem, 6vw, 5rem);">Not Sure Where<br>To Start?</h2>
      <p>Take our 30-second style quiz and get personalized outfit recommendations based on your aesthetic.</p>
      <a href="/style-quiz" class="btn btn-primary btn-lg">Take The Quiz <i class="fa-regular fa-arrow-right"></i></a>
    </div>
  </section>

  <!-- Community Wall -->
  <section class="section" id="community">
    <div class="section-head">
      <div>
        <span class="section-tag">#STREETARCHIVE</span>
        <h2 class="section-title">As Seen On You</h2>
      </div>
      <button class="section-link" id="uploadPhotoBtn">Upload Yours <i class="fa-regular fa-camera"></i></button>
    </div>
    <div class="community-grid">
      <% if (typeof community !== 'undefined' && community.length > 0) { %>
        <% community.forEach(function(c) { %>
          <div class="community-card">
            <img src="<%= c.image %>" alt="<%= c.name %>" loading="lazy">
            <div class="community-card-overlay">
              <p>"<%= c.caption %>"</p>
              <span>— <%= c.name %></span>
              <span class="community-likes"><i class="fa-regular fa-heart"></i> <%= c.likes %></span>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section" id="testimonials">
    <div class="section-head">
      <div>
        <span class="section-tag">Endorsements</span>
        <h2 class="section-title">Trusted By</h2>
      </div>
    </div>
    <div class="testimonial-grid">
      <% if (typeof testimonials !== 'undefined' && testimonials.length > 0) { %>
        <% testimonials.forEach(function(t) { %>
          <div class="testimonial-card">
            <div class="testimonial-stars"><% for(let s=0; s<t.rating; s++){ %><i class="fa-regular fa-star"></i><% } %></div>
            <p class="testimonial-text">"<%= t.content %>"</p>
            <div class="testimonial-author">
              <img src="<%= t.image %>" alt="<%= t.name %>" loading="lazy">
              <div>
                <strong><%= t.name %></strong>
                <span><%= t.role %></span>
              </div>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </section>

  <!-- Blog -->
  <section class="section" id="journal">
    <div class="section-head">
      <div>
        <span class="section-tag">Journal</span>
        <h2 class="section-title">From The Archive</h2>
      </div>
    </div>
    <div class="blog-grid">
      <% if (typeof blog !== 'undefined' && blog.length > 0) { %>
        <% blog.slice(0, 3).forEach(function(b) { %>
          <article class="blog-card">
            <div class="blog-card-image">
              <img src="<%= b.image %>" alt="<%= b.title %>" loading="lazy">
              <span class="blog-category"><%= b.category %></span>
            </div>
            <div class="blog-card-body">
              <div class="blog-meta">
                <span><%= b.date %></span>
                <span><%= b.readTime %></span>
              </div>
              <h3><%= b.title %></h3>
              <p><%= b.excerpt %></p>
            </div>
          </article>
        <% }); %>
      <% } %>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" id="faq">
    <div class="section-head">
      <div>
        <span class="section-tag">Questions</span>
        <h2 class="section-title">FAQ</h2>
      </div>
    </div>
    <div class="faq-list">
      <% if (typeof faq !== 'undefined' && faq.length > 0) { %>
        <% faq.forEach(function(f, i) { %>
          <div class="faq-item">
            <button class="faq-question" onclick="this.parentElement.classList.toggle('open')">
              <%= f.question %>
              <i class="fa-regular fa-chevron-down"></i>
            </button>
            <div class="faq-answer"><p><%= f.answer %></p></div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </section>

  <!-- Sustainability Banner -->
  <section class="section sustain-banner">
    <div class="sustain-banner-content">
      <span class="section-tag">Impact</span>
      <h2 class="section-title">Built To Last,<br>Built Responsibly</h2>
      <p>Organic cotton. Recycled nylon. Carbon-neutral shipping. We're transparent about every material choice.</p>
      <div class="sustain-stats">
        <div><span>100%</span> Organic Cotton</div>
        <div><span>85%</span> Recycled Materials</div>
        <div><span>Zero</span> Single-Use Plastic</div>
      </div>
      <a href="/sustainability" class="btn btn-outline">Our Commitments <i class="fa-regular fa-arrow-right"></i></a>
    </div>
  </section>
</main>

<%- include('partials/footer') %>