<!DOCTYPE html>
<html class="dark" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Login - STREET_ARCHIVE</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
</head>
<body class="bg-background text-on-background antialiased min-h-screen flex flex-col">
<header class="flex justify-between items-center px-6 h-20 bg-white dark:bg-black border-b-3 border-black dark:border-white">
<div class="flex items-center gap-6">
<a href="/" class="text-3xl font-black tracking-tighter text-black dark:text-white">STREET_ARCHIVE</a>
</div>
</header>
<main class="flex-grow flex items-center justify-center p-8">
<div class="max-w-md w-full">
<h1 class="font-headline-xl text-headline-xl uppercase mb-8 text-center">LOGIN</h1>
<% if (typeof error !== 'undefined') { %>
  <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
    <%= error %>
  </div>
<% } %>
<form action="/login" method="POST" class="space-y-6">
  <div>
    <label for="email" class="block font-label-bold text-label-bold uppercase mb-2">Email</label>
    <input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-surface border-3 border-outline focus:border-primary outline-none">
  </div>
  <div>
    <label for="password" class="block font-label-bold text-label-bold uppercase mb-2">Password</label>
    <input type="password" id="password" name="password" required class="w-full px-4 py-3 bg-surface border-3 border-outline focus:border-primary outline-none">
  </div>
  <button type="submit" class="w-full bg-primary text-on-primary font-label-bold text-label-bold uppercase py-4 border-3 border-primary hover:bg-primary-container transition-colors duration-100">
    LOGIN
  </button>
</form>
<p class="text-center mt-8 text-primary">
  Demo: admin@streetarchive.com / admin
</p>
</div>
</main>
</body>
</html></content>
