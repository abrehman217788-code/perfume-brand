<!DOCTYPE html>
<html class="dark" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>STREET_ARCHIVE - Cart</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
tailwind.config = {
  darkMode: "class",
  theme: {
    extend: {
      "colors": {
        "surface": "#131313",
        "surface-bright": "#393939",
        "background": "#131313",
        "on-surface": "#e5e2e1",
        "on-background": "#e5e2e1",
        "tertiary": "#abd600",
        "on-tertiary": "#283500",
        "on-surface-variant": "#cfc4c5"
      },
      "borderWidth": {
        "3": "3px"
      },
      "fontFamily": {
        "headline-lg": ["Inter"],
        "label-mono": ["Inter"],
        "label-bold": ["Inter"],
        "headline-xl": ["Inter"]
      }
    }
  }
}
</script>
<style>
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
</style>
</head>
<body class="bg-background text-on-background antialiased pt-20 flex flex-col min-h-screen">
<!-- TopAppBar -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-20 bg-white dark:bg-black border-b-3 border-black dark:border-white">
<div class="flex items-center gap-10">
<a class="text-3xl font-black tracking-tighter text-black dark:text-white uppercase font-headline-lg" href="/">STREET_ARCHIVE</a>
<nav class="hidden md:flex items-center gap-6 font-inter uppercase tracking-tighter font-black text-sm">
<a class="text-gray-500 hover:text-white transition-colors p-2" href="/shop">SHOP</a>
<a class="text-gray-500 hover:text-white transition-colors p-2" href="/product">DROPS</a>
<a class="text-gray-500 hover:text-white transition-colors p-2" href="/">COLLECTIONS</a>
<a class="text-gray-500 hover:text-white transition-colors p-2" href="/about">LAB</a>
</nav>
</div>
<div class="flex items-center gap-4">
<a href="/cart" class="w-10 h-10 flex items-center justify-center text-white hover:bg-white hover:text-black border-2 border-transparent transition-all relative">
<span class="material-symbols-outlined">shopping_bag</span>
<% if (cart && cart.length > 0) { %>
<span class="absolute -top-1 -right-1 w-4 h-4 flex items-center justify-center text-[10px] font-bold bg-tertiary text-black border-2 border-white"><%= cart.length %></span>
<% } %>
</a>
</div>
</header>

<main class="flex-grow w-full max-w-5xl mx-auto px-6 py-12">
<h1 class="text-6xl font-black tracking-tighter mb-8 uppercase">YOUR BAG (<%= cart ? cart.length : 0 %>)</h1>

<% if (!cart || cart.length === 0) { %>
<div class="border-3 border-on-background p-12 text-center bg-surface">
<p class="font-label-mono text-on-surface-variant uppercase mb-6">Your bag is currently empty.</p>
<a href="/shop" class="inline-block bg-white text-black px-8 py-3 font-bold uppercase tracking-widest hover:bg-tertiary hover:text-black transition-colors">RETURN TO SHOP</a>
</div>
<% } else { %>
<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
  <div class="col-span-2 flex flex-col gap-4">
    <% cart.forEach((item, index) => { %>
    <div class="border-3 border-on-background bg-surface flex gap-4 p-4 items-center">
      <img src="<%= item.image %>" class="w-24 h-24 object-cover grayscale contrast-125 border-3 border-on-background" />
      <div class="flex-grow">
        <h3 class="font-bold uppercase"><%= item.name %></h3>
        <p class="font-label-mono text-on-surface-variant text-sm"><%= item.code %></p>
      </div>
      <div class="text-right">
        <p class="font-bold text-xl mb-2">$<%= item.price %></p>
        <form action="/cart/remove" method="POST">
          <input type="hidden" name="index" value="<%= index %>">
          <button class="text-xs font-label-mono text-red-500 hover:text-white uppercase border border-red-500 hover:bg-red-500 px-2 py-1 transition-colors">REMOVE</button>
        </form>
      </div>
    </div>
    <% }) %>
  </div>
  
  <div class="col-span-1">
    <div class="border-3 border-on-background p-6 bg-surface sticky top-24">
      <h2 class="font-bold uppercase text-xl mb-6 border-b-2 border-on-surface-variant pb-2">ORDER SUMMARY</h2>
      <div class="flex justify-between font-label-mono mb-4">
        <span>SUBTOTAL</span>
        <span>$<%= cartTotal %></span>
      </div>
      <div class="flex justify-between font-label-mono mb-6">
        <span>SHIPPING</span>
        <span>CALCULATED AT CHECKOUT</span>
      </div>
      <div class="flex justify-between font-bold text-2xl mb-8 border-t-2 border-on-background pt-4">
        <span>TOTAL</span>
        <span class="text-tertiary">$<%= cartTotal %></span>
      </div>
      <form action="/checkout" method="POST">
        <button type="submit" class="w-full bg-white text-black py-4 font-black tracking-widest uppercase hover:bg-tertiary hover:text-black transition-all">CHECKOUT NOW</button>
      </form>
    </div>
  </div>
</div>
<% } %>
</main>
</body>
</html>
