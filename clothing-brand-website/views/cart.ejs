<%- include('partials/header') %>

<main class="cart-page">
  <div class="page-header">
    <div class="page-header-content">
      <h1>Your Bag <% if (typeof cart !== 'undefined') { %>(<%= cart.reduce((t,i) => t + (i.qty||1), 0) %>)<% } %></h1>
    </div>
  </div>

  <% if (!cart || cart.length === 0) { %>
  <section class="empty-state-section">
    <div class="empty-state">
      <i class="fa-regular fa-bag-shopping" style="font-size:4rem;color:var(--text-muted);margin-bottom:1.5rem;display:block;"></i>
      <h2>Your bag is empty</h2>
      <p>Ready to gear up? Explore our latest drops.</p>
      <a href="/shop" class="btn btn-primary">Shop Now <i class="fa-regular fa-arrow-right"></i></a>
    </div>
  </section>
  <% } else { %>
  <section class="cart-layout">
    <div class="cart-items">
      <% cartItems.forEach(function(item, idx) { %>
        <div class="cart-item">
          <div class="cart-item-image">
            <a href="/product/<%= item.product?.id || '' %>">
              <img src="<%= item.product?.image || 'https://images.unsplash.com/photo-1558618666-fcd25c85f82e?auto=format&fit=crop&q=80&w=200' %>" alt="<%= item.product?.name || item.sku %>" loading="lazy">
            </a>
          </div>
          <div class="cart-item-body">
            <h3><a href="/product/<%= item.product?.id || '' %>"><%= item.product?.name || item.sku %></a></h3>
            <p class="cart-item-sku"><%= item.sku %></p>
            <div class="cart-item-controls">
              <form action="/cart/update" method="POST" class="cart-qty-form">
                <input type="hidden" name="sku" value="<%= item.sku %>">
                <button type="button" onclick="this.parentElement.querySelector('input[name=qty]').stepDown();this.parentElement.submit()">−</button>
                <input type="number" name="qty" value="<%= item.qty || 1 %>" min="1" max="10" readonly>
                <button type="button" onclick="this.parentElement.querySelector('input[name=qty]').stepUp();this.parentElement.submit()">+</button>
              </form>
              <form action="/cart/remove" method="POST">
                <input type="hidden" name="sku" value="<%= item.sku %>">
                <button type="submit" class="cart-remove-btn"><i class="fa-regular fa-trash-can"></i></button>
              </form>
            </div>
          </div>
          <div class="cart-item-total">
            $<%= (item.product?.price || 0) * (item.qty || 1) %>
          </div>
        </div>
      <% }); %>
    </div>

    <div class="cart-summary">
      <div class="cart-summary-card">
        <h3>Order Summary</h3>
        <div class="summary-row"><span>Subtotal</span><span>$<%= cartTotal %></span></div>
        <div class="summary-row"><span>Shipping</span><span>Calculated at checkout</span></div>
        <div class="summary-row total"><span>Total</span><span>$<%= cartTotal %></span></div>
        
        <div class="payment-options" style="margin:1rem 0;">
          <span style="font-size:0.75rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--text-muted);">Buy now, pay later</span>
          <div class="payment-logos">
            <span class="payment-badge">Klarna</span>
            <span class="payment-badge">Afterpay</span>
            <span class="payment-badge">PayPal</span>
          </div>
        </div>

        <a href="/checkout" class="btn btn-primary btn-lg" style="width:100%;justify-content:center;">Checkout <i class="fa-regular fa-arrow-right"></i></a>
        <a href="/shop" class="btn btn-outline" style="width:100%;justify-content:center;margin-top:0.5rem;">Continue Shopping</a>
      </div>
    </div>
  </section>
  <% } %>
</main>

<%- include('partials/footer') %>