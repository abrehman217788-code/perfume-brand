<%- include('partials/header') %>

<main>
  <div class="page-header">
    <div class="page-header-content">
      <span class="section-tag" style="color:var(--tertiary)">Responsibility</span>
      <h1>Sustainability</h1>
      <p>Transparent about our impact. Committed to doing better.</p>
    </div>
  </div>

  <section class="section">
    <div class="sustain-grid">
      <div class="sustain-card">
        <i class="fa-regular fa-leaf"></i>
        <h3>100% Organic Cotton</h3>
        <p>All cotton products are GOTS-certified organic. Grown without synthetic pesticides or fertilizers.</p>
      </div>
      <div class="sustain-card">
        <i class="fa-regular fa-recycle"></i>
        <h3>Recycled Materials</h3>
        <p>85% of our nylon and polyester is post-consumer recycled. We're targeting 100% by 2028.</p>
      </div>
      <div class="sustain-card">
        <i class="fa-regular fa-droplet"></i>
        <h3>Low-Impact Dyes</h3>
        <p>Our garment-dye process uses 60% less water and zero hazardous chemicals.</p>
      </div>
      <div class="sustain-card">
        <i class="fa-regular fa-truck"></i>
        <h3>Carbon-Neutral Shipping</h3>
        <p>We offset all shipping emissions through verified carbon credits. Free shipping on orders over $150.</p>
      </div>
      <div class="sustain-card">
        <i class="fa-regular fa-box"></i>
        <h3>Zero Single-Use Plastic</h3>
        <p>All packaging is made from 100% recycled materials and is fully recyclable.</p>
      </div>
      <div class="sustain-card">
        <i class="fa-regular fa-handshake"></i>
        <h3>Fair Trade Certified</h3>
        <p>All manufacturing partners are Fair Trade certified. Workers earn fair wages in safe conditions.</p>
      </div>
    </div>

    <div class="sustain-report" style="margin-top:4rem;padding:2rem;background:var(--surface);border:1px solid var(--border);">
      <h3>Our Progress</h3>
      <div class="sustain-metrics">
        <div><span>2024</span><div class="meter"><div style="width:60%"></div></div><span>60% recycled</span></div>
        <div><span>2025</span><div class="meter"><div style="width:75%"></div></div><span>75% recycled</span></div>
        <div><span>2026</span><div class="meter"><div style="width:85%"></div></div><span>85% recycled</span></div>
        <div><span>2028</span><div class="meter"><div style="width:100%"></div></div><span>Target: 100%</span></div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>