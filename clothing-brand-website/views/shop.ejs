<!DOCTYPE html>
<html class="dark" lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>STREET_ARCHIVE - Shop</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;800;900&display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
<script id="tailwind-config">
tailwind.config = {
  darkMode: "class",
  theme: {
    extend: {
      "colors": {
        "on-error-container": "#ffdad6",
        "secondary-container": "#454747",
        "on-primary": "#303030",
        "on-primary-fixed": "#1b1b1b",
        "on-secondary": "#2f3131",
        "on-tertiary-container": "#647f00",
        "secondary-fixed-dim": "#c6c6c7",
        "secondary-fixed": "#e2e2e2",
        "tertiary-fixed-dim": "#abd600",
        "on-primary-fixed-variant": "#474747",
        "on-tertiary-fixed-variant": "#3c4d00",
        "surface": "#131313",
        "primary-fixed": "#e2e2e2",
        "primary-fixed-dim": "#c6c6c6",
        "surface-bright": "#393939",
        "on-secondary-fixed": "#1a1c1c",
        "outline-variant": "#4c4546",
        "tertiary": "#abd600",
        "background": "#131313",
        "on-secondary-container": "#b4b5b5",
        "tertiary-fixed": "#c3f400",
        "surface-dim": "#131313",
        "inverse-on-surface": "#313030",
        "primary-container": "#000000",
        "surface-container-highest": "#353535",
        "on-surface": "#e5e2e1",
        "on-tertiary-fixed": "#161e00",
        "outline": "#988e90",
        "surface-container-high": "#2a2a2a",
        "surface-container": "#20201f",
        "secondary": "#c6c6c7",
        "inverse-primary": "#5e5e5e",
        "on-surface-variant": "#cfc4c5",
        "surface-tint": "#c6c6c6",
        "on-error": "#690005",
        "tertiary-container": "#000000",
        "error": "#ffb4ab",
        "on-primary-container": "#757575",
        "inverse-surface": "#e5e2e1",
        "on-tertiary": "#283500",
        "on-secondary-fixed-variant": "#454747",
        "surface-container-low": "#1c1b1b",
        "surface-variant": "#353535",
        "on-background": "#e5e2e1",
        "primary": "#c6c6c6",
        "surface-container-lowest": "#0e0e0e",
        "error-container": "#93000a"
      },
      "borderRadius": {
        "DEFAULT": "0.25rem",
        "lg": "0.5rem",
        "xl": "0.75rem",
        "full": "9999px"
      },
      "spacing": {
        "unit": "8px",
        "border-thin": "1px",
        "border-thick": "3px",
        "margin": "40px",
        "gutter": "24px",
        "container-max": "1440px"
      },
      "fontFamily": {
        "headline-2xl": ["Inter"],
        "label-mono": ["Inter"],
        "headline-lg": ["Inter"],
        "label-bold": ["Inter"],
        "body-lg": ["Inter"],
        "headline-xl": ["Inter"],
        "body-md": ["Inter"]
      },
      "fontSize": {
        "headline-2xl": ["120px", { "lineHeight": "100px", "letterSpacing": "-0.05em", "fontWeight": "900" }],
        "label-mono": ["12px", { "lineHeight": "14px", "letterSpacing": "0.1em", "fontWeight": "500" }],
        "headline-lg": ["48px", { "lineHeight": "48px", "letterSpacing": "-0.02em", "fontWeight": "800" }],
        "label-bold": ["14px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "700" }],
        "body-lg": ["18px", { "lineHeight": "28px", "letterSpacing": "0em", "fontWeight": "400" }],
        "headline-xl": ["72px", { "lineHeight": "72px", "letterSpacing": "-0.03em", "fontWeight": "800" }],
        "body-md": ["16px", { "lineHeight": "24px", "letterSpacing": "0em", "fontWeight": "400" }]
      }
    }
  }
}
</script>
<style>
.material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
.icon-fill { font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
</style>
</head>
<body class="bg-background text-on-background antialiased pt-20 flex flex-col min-h-screen selection:bg-tertiary selection:text-on-tertiary">
<!-- TopAppBar -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-6 h-20 bg-white dark:bg-black border-b-3 border-black dark:border-white">
<div class="flex items-center gap-10">
<a class="text-3xl font-black tracking-tighter text-black dark:text-white uppercase" href="/">STREET_ARCHIVE</a>
<nav class="hidden md:flex items-center gap-6 font-inter uppercase tracking-tighter font-black text-sm">
<a class="text-black dark:text-white border-b-3 border-black dark:border-white pb-1 transition-colors duration-100" href="/shop">SHOP</a>
<a class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors duration-100 p-2" href="/product">DROPS</a>
<a class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors duration-100 p-2" href="/">COLLECTIONS</a>
<a class="text-gray-500 dark:text-gray-400 hover:text-black dark:hover:text-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors duration-100 p-2" href="/about">LAB</a>
</nav>
</div>
<div class="flex items-center gap-4 text-black dark:text-white">
<a href="/cart" class="w-10 h-10 flex items-center justify-center hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black border-2 border-transparent hover:border-black dark:hover:border-white transition-all duration-100 relative">
<span class="material-symbols-outlined">shopping_bag</span>
<% if (typeof cart !== 'undefined' && cart.length > 0) { %>
<span class="absolute -top-1 -right-1 w-4 h-4 bg-tertiary border-2 border-black dark:border-white flex items-center justify-center text-[10px] font-bold text-black"><%= cart.length %></span>
<% } %>
</a>
<% if (user) { %>
  <a href="/logout" class="w-10 h-10 flex items-center justify-center hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black border-2 border-transparent hover:border-black dark:hover:border-white transition-all duration-100">
    <span class="material-symbols-outlined">logout</span>
  </a>
<% } else { %>
  <a href="/login" class="w-10 h-10 flex items-center justify-center hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black border-2 border-transparent hover:border-black dark:hover:border-white transition-all duration-100">
    <span class="material-symbols-outlined">person</span>
  </a>
<% } %>
<button class="md:hidden w-10 h-10 flex items-center justify-center hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-all duration-100">
<span class="material-symbols-outlined">menu</span>
</button>
</div>
</header>
<!-- Main Content -->
<main class="flex-grow w-full max-w-container-max mx-auto px-6 py-12 grid grid-cols-12 gap-gutter">
<!-- Header / Filters Top Bar -->
<div class="col-span-12 mb-10 flex flex-col md:flex-row justify-between items-start md:items-end border-b-3 border-on-background pb-6 gap-6">
<div>
<h1 class="font-headline-xl text-on-background uppercase tracking-tighter">ALL GEAR</h1>
<p class="font-body-md text-on-surface-variant mt-2 max-w-lg">Engineered for the concrete. Unapologetic utility meets high-contrast brutalism. Limited runs only.</p>
</div>
<div class="flex flex-wrap gap-4 items-center w-full md:w-auto">
<div class="relative w-full md:w-48">
<select class="w-full bg-transparent border-3 border-on-background text-on-background font-label-mono uppercase py-3 px-4 appearance-none rounded-none focus:outline-none focus:border-tertiary focus:ring-0 cursor-pointer" id="categoryFilter" onchange="filterProducts()">
<option value="all">CATEGORY: ALL</option>
<option value="HOODIES">HOODIES</option>
<option value="CARGO">CARGOS</option>
<option value="TEES">TEES</option>
<option value="ACCESSORIES">ACCESSORIES</option>
</select>
<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none">expand_more</span>
</div>
<div class="relative w-full md:w-48">
<select class="w-full bg-transparent border-3 border-on-background text-on-background font-label-mono uppercase py-3 px-4 appearance-none rounded-none focus:outline-none focus:border-tertiary focus:ring-0 cursor-pointer" id="sortFilter" onchange="filterProducts()">
<option value="new">SORT: NEWEST</option>
<option value="price-asc">PRICE: LOW-HIGH</option>
<option value="price-desc">PRICE: HIGH-LOW</option>
</select>
<span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none">expand_more</span>
</div>
</div>
</div>
<!-- Product Grid -->
<div class="col-span-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-gutter" id="productGrid">
<% if (typeof products !== 'undefined' && products.length > 0) { %>
<% products.forEach((product, index) => { %>
<article class="group border-3 border-on-background flex flex-col relative bg-surface overflow-hidden <%= product.isSoldOut ? 'opacity-75' : '' %>" data-category="<%= product.category %>" data-price="<%= product.price %>">
<div class="w-full aspect-[4/5] bg-surface-container border-b-3 border-on-background overflow-hidden relative">
<img alt="<%= product.name %>" class="w-full h-full object-cover grayscale contrast-125 group-hover:scale-105 transition-transform duration-500" src="<%= product.image %>"/>
<% if (product.isSoldOut) { %>
<div class="absolute inset-0 bg-background/50 flex items-center justify-center backdrop-blur-sm">
<div class="bg-error text-on-error font-label-mono px-6 py-2 border-3 border-error-container transform -rotate-12 shadow-[4px_4px_0px_#93000a] uppercase tracking-widest text-lg">SOLD OUT</div>
</div>
<% } else if (product.isNewDrop) { %>
<div class="absolute top-4 left-4 bg-tertiary text-on-tertiary font-label-mono px-3 py-1 border-2 border-on-background">NEW DROP</div>
<% } else if (product.isLimited) { %>
<div class="absolute top-4 left-4 bg-primary text-on-primary font-label-mono px-3 py-1 border-2 border-on-background">LIMITED</div>
<% } %>
</div>
<div class="p-4 flex flex-col flex-grow bg-surface">
<h3 class="font-label-bold text-on-background uppercase truncate mb-1"><%= product.name %></h3>
<p class="font-label-mono text-on-surface-variant mb-4"><%= product.sku || product.code || product.category %></p>
<div class="mt-auto flex justify-between items-end">
<span class="font-headline-lg text-on-background leading-none">$<%= product.price %></span>
<form action="/cart/add" method="POST">
<input type="hidden" name="productId" value="<%= product._id || product.id %>">
<button type="submit" class="border-2 border-on-background px-4 py-2 font-label-mono uppercase hover:bg-on-background hover:text-background transition-colors <%= product.isSoldOut ? 'border-surface-variant text-surface-variant cursor-not-allowed' : '' %>" <%= product.isSoldOut ? 'disabled' : '' %>><%= product.isSoldOut ? 'N/A' : 'ADD' %></button>
</form>
</div>
</div>
</article>
<% }); %>
<% } else { %>
<div class="col-span-12 text-center py-24">
<p class="font-headline-lg text-on-surface-variant">NO PRODUCTS AVAILABLE</p>
</div>
<% } %>
</div>
<!-- Pagination / Load More -->
<div class="col-span-12 mt-16 flex justify-center border-t-3 border-on-background pt-8">
<button class="border-3 border-on-background bg-background text-on-background px-12 py-4 font-label-bold uppercase tracking-widest hover:bg-on-background hover:text-background transition-colors flex items-center gap-2">
LOAD MORE FRAGMENTS
<span class="material-symbols-outlined">arrow_downward</span>
</button>
</div>
</main>
<!-- Footer -->
<footer class="w-full py-12 px-10 grid grid-cols-12 gap-6 items-end bg-white dark:bg-black border-t-3 border-black dark:border-white docked full-width mt-auto">
<div class="col-span-12 md:col-span-6 flex flex-col gap-4">
<h2 class="text-xl font-black text-black dark:text-white uppercase">STREET_ARCHIVE</h2>
<p class="font-inter font-bold uppercase text-xs tracking-widest text-black dark:text-white">&copy;2024 STREET_ARCHIVE. ALL RIGHTS RESERVED.</p>
</div>
<div class="col-span-12 md:col-span-6 flex flex-wrap justify-start md:justify-end gap-6 font-inter font-bold uppercase text-xs tracking-widest">
<a class="text-black dark:text-white hover:invert transition-all duration-75" href="#">PRIVACY</a>
<a class="text-black dark:text-white hover:invert transition-all duration-75" href="#">TERMS</a>
<a class="text-black dark:text-white hover:invert transition-all duration-75" href="#">SHIPPING</a>
<a class="text-black dark:text-white hover:invert transition-all duration-75" href="#">CONTACT</a>
</div>
</footer>
<script>
function filterProducts() {
  const cat = document.getElementById('categoryFilter').value;
  const sort = document.getElementById('sortFilter').value;
  const grid = document.getElementById('productGrid');
  const cards = grid.querySelectorAll('article');
  const visible = [];
  cards.forEach(card => {
    const c = card.dataset.category;
    const match = cat === 'all' || c === cat;
    card.style.display = match ? '' : 'none';
    if (match) visible.push(card);
  });
  if (sort === 'price-asc') {
    visible.sort((a, b) => +a.dataset.price - +b.dataset.price);
  } else if (sort === 'price-desc') {
    visible.sort((a, b) => +b.dataset.price - +a.dataset.price);
  }
  visible.forEach(el => grid.appendChild(el));
}
</script>
</body>
</html>
