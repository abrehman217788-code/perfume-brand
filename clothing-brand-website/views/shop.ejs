<%- include('partials/header') %>

<main>
  <section class="page-header">
    <div class="page-header-content">
      <h1>All Gear</h1>
      <p>Engineered for the concrete. Unapologetic utility meets high-contrast brutalism. Limited runs only.</p>
    </div>
  </section>

  <section class="shop-controls">
    <div class="shop-filters">
      <div class="filter-group">
        <select id="catFilter" onchange="applyFilters()">
          <option value="all">All Categories</option>
          <% if (typeof categories !== 'undefined') { categories.forEach(function(c) { %>
            <option value="<%= c %>"><%= c %></option>
          <% }); } %>
        </select>
      </div>
      <div class="filter-group">
        <select id="sortFilter" onchange="applyFilters()">
          <option value="newest">Newest</option>
          <option value="price-asc">Price: Low → High</option>
          <option value="price-desc">Price: High → Low</option>
          <option value="rating">Top Rated</option>
        </select>
      </div>
      <div class="filter-group">
        <select id="sizeFilter" onchange="applyFilters()">
          <option value="all">All Sizes</option>
          <option value="S">S</option>
          <option value="M">M</option>
          <option value="L">L</option>
          <option value="XL">XL</option>
        </select>
      </div>
      <div class="filter-group">
        <label class="filter-toggle">
          <input type="checkbox" id="saleFilter" onchange="applyFilters()"> Sale Only
        </label>
      </div>
    </div>
    <div class="shop-results-count" id="resultsCount"></div>
  </section>

  <section class="shop-grid-section">
    <div class="product-grid" id="productGrid">
      <% if (typeof products !== 'undefined' && products.length > 0) { %>
        <% products.forEach(function(p) { %>
          <a href="/product/<%= p.id %>" class="product-card <%= p.isSoldOut ? 'sold-out' : '' %>" data-category="<%= p.category %>" data-price="<%= p.price %>" data-rating="<%= p.rating %>" data-sizes="<%= Object.keys(p.inStock).filter(s => p.inStock[s] > 0).join(',') %>" data-sale="<%= p.originalPrice ? 'true' : 'false' %>" data-created="<%= p.createdAt %>">
            <div class="product-card-image">
              <img src="<%= p.image %>" alt="<%= p.name %>" loading="lazy">
              <div class="product-card-actions">
                <button class="quick-add" onclick="event.preventDefault();quickAdd('<%= p.id %>')" <%= p.isSoldOut ? 'disabled' : '' %>>
                  <i class="fa-regular fa-bag-shopping"></i> Quick Add
                </button>
              </div>
              <% if (p.isNewDrop) { %><span class="product-badge new">New</span><% } %>
              <% if (p.isLimited) { %><span class="product-badge limited">Limited</span><% } %>
              <% if (p.isSoldOut) { %><span class="product-badge sold">Sold Out</span><% } %>
              <% if (p.originalPrice) { %><span class="product-badge sale">-<%= Math.round((1 - p.price/p.originalPrice) * 100) %>%</span><% } %>
            </div>
            <div class="product-card-body">
              <span class="product-card-sku"><%= p.sku %></span>
              <h3 class="product-card-title"><%= p.name %></h3>
              <div class="product-card-colors">
                <% p.colors.slice(0, 3).forEach(function(c) { %>
                  <span class="color-dot" style="background:<%= c === 'Black' ? '#000' : c === 'White' ? '#fff' : c === 'Olive' ? '#556b2f' : c === 'Grey' ? '#888' : c === 'Charcoal' ? '#444' : c === 'Bone' ? '#e8dcc8' : c === 'Clay' ? '#8b7355' : c === 'Orange' ? '#ff6600' : c === 'Navy' ? '#000080' : c === 'Sand' ? '#c2b280' : c === 'Graphite' ? '#555' : '#999' %>"></span>
                <% }); %>
                <% if (p.colors.length > 3) { %><span class="color-more">+<%= p.colors.length - 3 %></span><% } %>
              </div>
              <div class="product-card-footer">
                <span class="product-card-price">
                  <% if (p.originalPrice) { %><del>$<%= p.originalPrice %></del> <% } %>
                  $<%= p.price %>
                </span>
                <span class="product-card-rating"><i class="fa-regular fa-star"></i> <%= p.rating %></span>
              </div>
            </div>
          </a>
        <% }); %>
      <% } else { %>
        <div class="empty-state">
          <i class="fa-regular fa-box-open" style="font-size:3rem;color:var(--text-muted);margin-bottom:1rem;display:block;"></i>
          <p>No products found. Try adjusting your filters.</p>
        </div>
      <% } %>
    </div>
  </section>

  <section class="email-capture">
    <div class="email-capture-content">
      <h3>Always Sold Out? Get Early Access.</h3>
      <p>Subscribe for drop alerts and archive exclusives before the public.</p>
      <form class="newsletter-form" id="shopNewsletter">
        <input type="email" placeholder="Your email address" required>
        <button type="submit">Subscribe <i class="fa-regular fa-arrow-right"></i></button>
      </form>
    </div>
  </section>
</main>

<script>
function applyFilters() {
  const cat = document.getElementById('catFilter').value;
  const sort = document.getElementById('sortFilter').value;
  const size = document.getElementById('sizeFilter').value;
  const saleOnly = document.getElementById('saleFilter').checked;
  const grid = document.getElementById('productGrid');
  const cards = Array.from(grid.querySelectorAll('.product-card'));
  let visible = [];
  cards.forEach(c => {
    let show = true;
    if (cat !== 'all' && c.dataset.category !== cat) show = false;
    if (size !== 'all' && !c.dataset.sizes.split(',').includes(size)) show = false;
    if (saleOnly && c.dataset.sale !== 'true') show = false;
    c.style.display = show ? '' : 'none';
    if (show) visible.push(c);
  });
  if (sort === 'price-asc') visible.sort((a, b) => +a.dataset.price - +b.dataset.price);
  else if (sort === 'price-desc') visible.sort((a, b) => +b.dataset.price - +a.dataset.price);
  else if (sort === 'rating') visible.sort((a, b) => +b.dataset.rating - +a.dataset.rating);
  else if (sort === 'newest') visible.sort((a, b) => b.dataset.created.localeCompare(a.dataset.created));
  visible.forEach(el => grid.appendChild(el));
  document.getElementById('resultsCount').textContent = visible.length + ' products';
}
function quickAdd(id) {
  fetch('/cart/add', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:'sku=SA-' + id.slice(-3).toUpperCase() + '&qty=1' })
    .then(() => { window.location.href = '/cart'; });
}
document.addEventListener('DOMContentLoaded', applyFilters);
</script>

<%- include('partials/footer') %>