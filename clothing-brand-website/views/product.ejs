<%- include('partials/header') %>

<main class="product-page">
  <div class="product-layout">
    <!-- 3D Viewer + Gallery -->
    <div class="product-gallery">
      <div class="product-main-image" id="productMainImage">
        <img src="<%= product.image %>" alt="<%= product.name %>" id="mainImg">
        <button class="gallery-btn zoom-btn" id="zoomBtn" onclick="toggleZoom()"><i class="fa-regular fa-expand"></i></button>
        <button class="gallery-btn ar-btn" onclick="openAR()"><i class="fa-regular fa-cube"></i> AR</button>
      </div>
      <div class="product-thumbnails" id="thumbnails">
        <% if (typeof product.images !== 'undefined') { product.images.forEach(function(img, i) { %>
          <button class="thumb <%= i === 0 ? 'active' : '' %>" onclick="switchImage('<%= img %>', this)">
            <img src="<%= img %>" alt="" loading="lazy">
          </button>
        <% }); } %>
      </div>
      <!-- Fabric swatch -->
      <div class="fabric-swatch">
        <span class="fabric-label">Fabric</span>
        <span class="fabric-value"><%= product.fabric %></span>
        <button class="fabric-closeup" onclick="openFabricZoom()"><i class="fa-regular fa-search-plus"></i> Close-up</button>
      </div>
    </div>

    <!-- Product Info -->
    <div class="product-info">
      <div class="product-breadcrumb">
        <a href="/shop"><%= product.category %></a> / <span><%= product.name %></span>
      </div>
      
      <% if (product.isNewDrop) { %><span class="product-badge new">New Drop</span><% } %>
      <% if (product.isLimited) { %><span class="product-badge limited">Limited Edition</span><% } %>
      <% if (product.isSoldOut) { %><span class="product-badge sold">Sold Out</span><% } %>

      <h1 class="product-name"><%= product.name %></h1>
      <p class="product-sku"><%= product.sku %></p>
      
      <div class="product-price-row">
        <span class="product-price">
          <% if (product.originalPrice) { %><del>$<%= product.originalPrice %></del> <% } %>
          $<%= product.price %>
        </span>
        <span class="product-rating">
          <i class="fa-regular fa-star"></i> <%= product.rating %> (<%= product.reviewCount %> reviews)
        </span>
      </div>

      <div class="product-colors">
        <span class="color-label">Color: <strong id="selectedColor"><%= product.colors[0] %></strong></span>
        <div class="color-options">
          <% product.colors.forEach(function(c) { %>
            <button class="color-swatch <%= c === product.colors[0] ? 'active' : '' %>" style="background:<%= c === 'Black' ? '#000' : c === 'White' ? '#fff' : c === 'Olive' ? '#556b2f' : c === 'Grey' ? '#888' : c === 'Charcoal' ? '#444' : c === 'Bone' ? '#e8dcc8' : c === 'Clay' ? '#8b7355' : c === 'Orange' ? '#ff6600' : c === 'Navy' ? '#000080' : c === 'Sand' ? '#c2b280' : c === 'Graphite' ? '#555' : '#999' %>" onclick="selectColor('<%= c %>', this)" aria-label="<%= c %>"></button>
          <% }); %>
        </div>
      </div>

      <div class="product-sizes">
        <div class="size-header">
          <span>Select Size</span>
          <button class="size-guide-btn" onclick="openSizeGuide()"><i class="fa-regular fa-ruler"></i> Size Guide</button>
        </div>
        <div class="size-options" id="sizeOptions">
          <% product.sizes.forEach(function(s) { %>
            <button class="size-btn <%= product.inStock[s] > 0 ? '' : 'disabled' %>" data-size="<%= s %>" onclick="selectSize('<%= s %>', this)" <%= product.inStock[s] === 0 ? 'disabled' : '' %>>
              <%= s %>
              <% if (product.inStock[s] <= 3 && product.inStock[s] > 0) { %><span class="low-stock">Low</span><% } %>
            </button>
          <% }); %>
        </div>
      </div>

      <!-- Fit Predictor -->
      <div class="fit-predictor">
        <div class="fit-header" onclick="this.parentElement.classList.toggle('open')">
          <i class="fa-regular fa-robot"></i> Fit Predictor
          <i class="fa-regular fa-chevron-down"></i>
        </div>
        <div class="fit-body">
          <p>Get your perfect size in seconds.</p>
          <div class="fit-inputs">
            <input type="number" placeholder="Height (cm)" id="fitHeight">
            <input type="number" placeholder="Weight (kg)" id="fitWeight">
            <select id="fitPreference">
              <option value="slim">Slim</option>
              <option value="regular" selected>Regular</option>
              <option value="oversized">Oversized</option>
            </select>
            <button class="btn btn-sm btn-primary" onclick="predictFit()">Predict <i class="fa-regular fa-arrow-right"></i></button>
          </div>
          <div id="fitResult" class="fit-result"></div>
          <p class="fit-note">Model is 6'1 (185cm) wearing size M for regular fit.</p>
        </div>
      </div>

      <!-- Add to Cart -->
      <% if (!product.isSoldOut) { %>
        <form class="add-to-cart-form" action="/cart/add" method="POST" onsubmit="return validateCartForm(event)">
          <input type="hidden" name="sku" value="<%= product.sku %>">
          <div class="qty-selector">
            <button type="button" onclick="adjQty(-1)">−</button>
            <input type="number" name="qty" id="productQty" value="1" min="1" max="10" readonly>
            <button type="button" onclick="adjQty(1)">+</button>
          </div>
          <button type="submit" class="btn btn-primary btn-lg add-to-cart-btn">
            Add to Bag — $<%= product.price %>
          </button>
        </form>
        <div class="payment-options">
          <span>4 interest-free payments of $<%= (product.price / 4).toFixed(2) %> with</span>
          <div class="payment-logos">
            <span class="payment-badge">Klarna</span>
            <span class="payment-badge">Afterpay</span>
            <span class="payment-badge">PayPal</span>
          </div>
        </div>
      <% } %>

      <!-- Description -->
      <div class="product-description">
        <p><%= product.description %></p>
        <ul class="product-details">
          <% product.details.forEach(function(d) { %>
            <li><i class="fa-regular fa-check"></i> <%= d %></li>
          <% }); %>
        </ul>
      </div>

      <!-- Sustainability -->
      <% if (product.sustainability) { %>
        <div class="product-sustainability">
          <i class="fa-regular fa-leaf"></i> Sustainability
          <ul>
            <% product.sustainability.forEach(function(s) { %>
              <li><%= s %></li>
            <% }); %>
          </ul>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Complete The Look -->
  <section class="section">
    <div class="section-head">
      <div>
        <span class="section-tag">Outfit Builder</span>
        <h2 class="section-title">Complete The Look</h2>
      </div>
    </div>
    <div class="product-grid">
      <% if (typeof related !== 'undefined' && related.length > 0) { %>
        <% related.forEach(function(r) { %>
          <a href="/product/<%= r.id %>" class="product-card">
            <div class="product-card-image">
              <img src="<%= r.image %>" alt="<%= r.name %>" loading="lazy">
            </div>
            <div class="product-card-body">
              <span class="product-card-sku"><%= r.sku %></span>
              <h3 class="product-card-title"><%= r.name %></h3>
              <span class="product-card-price">$<%= r.price %></span>
            </div>
          </a>
        <% }); %>
      <% } %>
    </div>
  </section>

  <!-- Customer Photos -->
  <section class="section">
    <div class="section-head">
      <div>
        <span class="section-tag">Community</span>
        <h2 class="section-title">Worn By You</h2>
      </div>
    </div>
    <div class="community-grid" style="grid-template-columns:repeat(4,1fr);">
      <div class="community-card">
        <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&q=80&w=400" alt="" loading="lazy">
        <div class="community-card-overlay"><p>"Perfect fit. Daily wear."</p><span>— Marcus</span></div>
      </div>
      <div class="community-card">
        <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&q=80&w=400" alt="" loading="lazy">
        <div class="community-card-overlay"><p>"Best hoodie I've owned."</p><span>— Elena</span></div>
      </div>
      <div class="community-card">
        <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&q=80&w=400" alt="" loading="lazy">
        <div class="community-card-overlay"><p>"Utility vest is essential."</p><span>— Jay</span></div>
      </div>
      <div class="community-card upload-card" onclick="document.getElementById('uploadPhotoModal').style.display='flex'">
        <i class="fa-regular fa-camera"></i>
        <span>Upload Yours</span>
      </div>
    </div>
  </section>
</main>

<!-- Size Guide Modal -->
<div class="modal" id="sizeGuideModal">
  <div class="modal-backdrop" onclick="closeSizeGuide()"></div>
  <div class="modal-content">
    <button class="modal-close" onclick="closeSizeGuide()"><i class="fa-regular fa-xmark"></i></button>
    <h2>Size Guide</h2>
    <p>Measurements in cm. Fit may vary by style.</p>
    <table>
      <tr><th>Size</th><th>Chest</th><th>Waist</th><th>Hip</th><th>Length</th></tr>
      <tr><td>S</td><td>96</td><td>81</td><td>96</td><td>71</td></tr>
      <tr><td>M</td><td>102</td><td>86</td><td>102</td><td>74</td></tr>
      <tr><td>L</td><td>107</td><td>91</td><td>107</td><td>76</td></tr>
      <tr><td>XL</td><td>112</td><td>97</td><td>112</td><td>79</td></tr>
    </table>
  </div>
</div>

<!-- Upload Photo Modal -->
<div class="modal" id="uploadPhotoModal">
  <div class="modal-backdrop" onclick="this.parentElement.style.display='none'"></div>
  <div class="modal-content">
    <button class="modal-close" onclick="document.getElementById('uploadPhotoModal').style.display='none'"><i class="fa-regular fa-xmark"></i></button>
    <h2>Share Your Look</h2>
    <p>Tag us @street_archive for a feature on our community wall.</p>
    <form id="uploadForm" onsubmit="event.preventDefault();uploadPhoto()">
      <input type="text" placeholder="Your name" id="uploadName" required>
      <textarea placeholder="Caption..." id="uploadCaption" rows="3"></textarea>
      <input type="url" placeholder="Photo URL" id="uploadUrl" required>
      <button type="submit" class="btn btn-primary">Submit for Review</button>
    </form>
  </div>
</div>

<script>
let selectedSize = null;
function switchImage(src, el) {
  document.getElementById('mainImg').src = src;
  document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}
function selectColor(color, el) {
  document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('selectedColor').textContent = color;
}
function selectSize(size, el) {
  document.querySelectorAll('.size-btn:not(.disabled)').forEach(s => s.classList.remove('active'));
  el.classList.add('active');
  selectedSize = size;
}
function validateCartForm(e) {
  if (!selectedSize) { alert('Please select a size.'); return false; }
  return true;
}
function adjQty(d) {
  const inp = document.getElementById('productQty');
  inp.value = Math.max(1, Math.min(10, +inp.value + d));
}
function predictFit() {
  const h = +document.getElementById('fitHeight').value;
  const w = +document.getElementById('fitWeight').value;
  const p = document.getElementById('fitPreference').value;
  const r = document.getElementById('fitResult');
  if (!h || !w) { r.innerHTML = '<span style="color:var(--error)">Please enter height and weight.</span>'; return; }
  const bmi = w / ((h/100) * (h/100));
  let size = 'M';
  if (bmi < 20) size = 'S';
  else if (bmi < 25) size = 'M';
  else if (bmi < 30) size = 'L';
  else size = 'XL';
  if (p === 'oversized') size = { S:'M', M:'L', L:'XL', XL:'XL' }[size] || 'XL';
  else if (p === 'slim') size = { S:'S', M:'S', L:'M', XL:'L' }[size] || 'M';
  r.innerHTML = '<span style="color:var(--tertiary);font-weight:700;font-size:1.2rem;">We recommend size <strong>' + size + '</strong></span>';
  document.querySelectorAll('.size-btn:not(.disabled)').forEach(s => s.classList.remove('active'));
  const btn = document.querySelector('.size-btn[data-size="' + size + '"]:not(.disabled)');
  if (btn) { btn.classList.add('active'); selectedSize = size; }
}
function toggleZoom() {
  const img = document.getElementById('mainImg');
  img.style.transform = img.style.transform === 'scale(2)' ? 'scale(1)' : 'scale(2)';
  img.style.cursor = img.style.transform === 'scale(2)' ? 'zoom-out' : 'zoom-in';
}
function openAR() { alert('AR Try-On: Point your camera at your body to see how this fits. (Demo mode)'); }
function openFabricZoom() { alert('Fabric Close-Up: 400% zoom view of textile weave. (Demo mode)'); }
function openSizeGuide() { document.getElementById('sizeGuideModal').style.display = 'flex'; }
function closeSizeGuide() { document.getElementById('sizeGuideModal').style.display = 'none'; }
function uploadPhoto() {
  const name = document.getElementById('uploadName').value;
  const caption = document.getElementById('uploadCaption').value;
  const url = document.getElementById('uploadUrl').value;
  if (!name || !url) return alert('Please fill in name and photo URL.');
  fetch('/api/community/upload', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({name, caption, url}) })
    .then(r => r.json()).then(d => { alert(d.message); document.getElementById('uploadPhotoModal').style.display='none'; });
}
</script>

<%- include('partials/footer') %>